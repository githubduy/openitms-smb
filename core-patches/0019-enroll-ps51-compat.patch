+Write-Host "==> 3/4  Set PowerShell as the default SSH shell" -ForegroundColor Cyan
 $pwsh = (Get-Command powershell.exe).Source
 New-ItemProperty -Path "HKLM:\SOFTWARE\OpenSSH" -Name DefaultShell `
   -Value $pwsh -PropertyType String -Force | Out-Null
 
-Write-Host "==> 4/4  Cấu hình authorized_keys" -ForegroundColor Cyan
+Write-Host "==> 4/4  Configure authorized_keys" -ForegroundColor Cyan
 if ([string]::IsNullOrWhiteSpace($PublicKey)) {
-  Write-Host "    (bỏ qua — chưa cung cấp -PublicKey)" -ForegroundColor Yellow
+  Write-Host "    (skipped - no -PublicKey provided)" -ForegroundColor Yellow
 } else {
   $admins = "$env:ProgramData\ssh\administrators_authorized_keys"
   Add-Content -Path $admins -Value $PublicKey -Encoding ascii
-  # Quyền chuẩn cho administrators_authorized_keys
+  # Correct permissions for administrators_authorized_keys
   icacls $admins /inheritance:r /grant "Administrators:F" /grant "SYSTEM:F" | Out-Null
-  Write-Host "    Đã thêm key vào $admins"
+  Write-Host "    Added key to $admins"
 }
 
 $ips = (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
@@ -68,14 +86,14 @@ $ips = (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
         Select-Object -ExpandProperty IPAddress) -join ', '
 
 Write-Host ""
-Write-Host "================= HOÀN TẤT =================" -ForegroundColor Green
-Write-Host "SSH server (sshd) đang chạy, cổng 22."
-Write-Host "IP máy này: $ips"
+Write-Host "================= DONE =================" -ForegroundColor Green
+Write-Host "SSH server (sshd) is running on port 22."
+Write-Host "This machine IP: $ips"
 Write-Host ""
 if ([string]::IsNullOrWhiteSpace($PublicKey)) {
-  Write-Host "CÒN LẠI: chạy lại với public key của OpenITMS:" -ForegroundColor Yellow
+  Write-Host "REMAINING: run again with the OpenITMS public key:" -ForegroundColor Yellow
   Write-Host '  .\openitms-ssh-enroll.ps1 -PublicKey "ssh-ed25519 AAAA... openitms"'
 } else {
-  Write-Host "BƯỚC TIẾP THEO: trên OpenITMS thêm private key (Key Store) + dùng IP máy này." -ForegroundColor Yellow
+  Write-Host "NEXT: in OpenITMS add the private key (Key Store) + use this machine IP." -ForegroundColor Yellow
 }
-Write-Host "==========================================="
+Write-Host "======================================="
