+// QUICKWIN PATCH 0007 — hook Service Manager vào core (status + restart hạ tầng).
+// Mount /api/services (list status) + /api/services/{name}/restart (admin).
+// Logic ở module ngoài cây upstream (quickwin.dev/servicemanager).
+// Spec: docs/L2-specs/core-patches/0007-service-manager.md
+package api
+
+import (
+	"net/http"
+	"os"
+	"strings"
+
+	"github.com/gorilla/mux"
+	log "github.com/sirupsen/logrus"
+
+	"github.com/semaphoreui/semaphore/util"
+
+	servicemanager "quickwin.dev/servicemanager"
+)
+
+// registerQuickwinServices mount API service trên subrouter đã authenticate.
+func registerQuickwinServices(authenticatedAPI *mux.Router) {
+	mgr := servicemanager.Default(
+		quickwinMariaDBAddr(),
+		os.Getenv("QUICKWIN_GITEA_ADDR"),
+		quickwinSelfAddr(),
+	)
+
+	authenticatedAPI.HandleFunc("/services", func(w http.ResponseWriter, r *http.Request) {
+		writeJSON(w, http.StatusOK, map[string]any{"services": mgr.List(r.Context())})
+	}).Methods("GET")
+
+	authenticatedAPI.HandleFunc("/services/{name}/restart", func(w http.ResponseWriter, r *http.Request) {
+		if u, ok := helpersUser(r); !ok || !u.Admin {
+			writeJSON(w, http.StatusForbidden, map[string]string{"error": "admin required"})
+			return
+		}
+		name := mux.Vars(r)["name"]
+		if err := mgr.Restart(r.Context(), name); err != nil {
+			writeJSON(w, http.StatusBadGateway, map[string]string{"error": err.Error()})
+			return
+		}
+		writeJSON(w, http.StatusOK, map[string]string{"restarted": name})
+	}).Methods("POST")
+
+	log.Info("quickwin: service manager mounted at api/services")
+}
+
+// quickwinMariaDBAddr — địa chỉ MariaDB để check status (từ config mysql host hoặc env).
+func quickwinMariaDBAddr() string {
+	if a := os.Getenv("QUICKWIN_MARIADB_ADDR"); a != "" {
+		return a
+	}
+	// từ config: nếu dialect mysql + host dạng host:port
+	if util.Config != nil && util.Config.MySQL != nil {
+		h := util.Config.MySQL.Hostname
+		if h == "" || h == "0.0.0.0" {
+			h = "127.0.0.1"
+		}
+		if strings.Contains(h, ":") {
+			return h
+		}
+		return h + ":3306"
+	}
+	return ""
+}
+
+// quickwinSelfAddr — địa chỉ chính app (chỉ để hiển thị status).
+func quickwinSelfAddr() string {
+	port := "3000"
+	if util.Config != nil && util.Config.Port != "" {
+		port = strings.TrimPrefix(util.Config.Port, ":")
+	}
+	return "127.0.0.1:" + port
+}
