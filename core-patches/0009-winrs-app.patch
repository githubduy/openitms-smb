diff --git a/db_lib/quickwin_winrs_app.go b/db_lib/quickwin_winrs_app.go
new file mode 100644
index 0000000..d6ac20d
--- /dev/null
+++ b/db_lib/quickwin_winrs_app.go
@@ -0,0 +1,129 @@
+// QUICKWIN PATCH 0009 — WinRSApp: execution engine chạy pwsh/lệnh xuống Windows từ xa
+// qua WinRM certificate auth (ADR: pwsh → SSH → winrs). Dùng inventory type "winrs"
+// (host + cert) + app type "winrs". Logic winrm dùng chung quickwin.dev/winrsexec.
+// Spec: docs/L2-specs/core-patches/0009-winrs-app.md
+package db_lib
+
+import (
+	"context"
+	"encoding/base64"
+	"fmt"
+	"os"
+	"path/filepath"
+	"time"
+	"unicode/utf16"
+
+	"github.com/semaphoreui/semaphore/db"
+	"github.com/semaphoreui/semaphore/pkg/task_logger"
+
+	"quickwin.dev/winrsexec"
+)
+
+// WinRSApp chạy 1 script pwsh (từ repo) xuống mọi host trong inventory WinRS.
+type WinRSApp struct {
+	Template   db.Template
+	Repository db.Repository
+	Inventory  db.Inventory
+	Logger     task_logger.Logger
+}
+
+func (t *WinRSApp) SetLogger(logger task_logger.Logger) task_logger.Logger {
+	t.Logger = logger
+	return logger
+}
+
+// InstallRequirements: WinRS không cần cài gì trên runner (kết nối trực tiếp WinRM).
+func (t *WinRSApp) InstallRequirements(LocalAppInstallingArgs) error { return nil }
+
+func (t *WinRSApp) Clear() {}
+
+// Run: đọc script từ repo, chạy trên từng host WinRS qua cert. Fail nếu bất kỳ host nào lỗi.
+func (t *WinRSApp) Run(args LocalAppRunningArgs) error {
+	script, err := t.readScript()
+	if err != nil {
+		return err
+	}
+	certsDir := os.Getenv("QUICKWIN_CERTS_DIR")
+	if certsDir == "" {
+		certsDir = "certs"
+	}
+	defaultCert := os.Getenv("QUICKWIN_WINRS_DEFAULT_CERT")
+
+	hosts := winrsexec.ParseHosts(t.Inventory.Inventory, defaultCert)
+	if len(hosts) == 0 {
+		return fmt.Errorf("inventory WinRS rỗng — khai báo host (mỗi dòng: 'host[:port] cert=<file.pem>')")
+	}
+	encoded := encodePowerShell(script)
+
+	var failed int
+	for _, h := range hosts {
+		t.Logger.Log(fmt.Sprintf("==> %s (cert=%s)", h.Addr, h.Cert))
+		if h.Cert == "" {
+			t.Logger.Log("  LỖI: host chưa khai cert (cert=<file> hoặc set QUICKWIN_WINRS_DEFAULT_CERT)")
+			failed++
+			continue
+		}
+		certPEM, err := os.ReadFile(filepath.Join(certsDir, h.Cert))
+		if err != nil {
+			t.Logger.Log("  LỖI đọc cert: " + err.Error())
+			failed++
+			continue
+		}
+		keyPEM := certPEM
+		if h.Key != "" {
+			if kp, kerr := os.ReadFile(filepath.Join(certsDir, h.Key)); kerr == nil {
+				keyPEM = kp
+			}
+		}
+		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Minute)
+		res, rerr := winrsexec.Run(ctx, winrsexec.Params{
+			Host: h.Addr, Port: h.Port, CertPEM: certPEM, KeyPEM: keyPEM,
+			Command: "powershell -EncodedCommand " + encoded, Timeout: 60 * time.Second,
+		})
+		cancel()
+		if rerr != nil {
+			t.Logger.Log("  " + winrsexec.Classify(rerr))
+			failed++
+			continue
+		}
+		if res.Stdout != "" {
+			t.Logger.Log(res.Stdout)
+		}
+		if res.Stderr != "" {
+			t.Logger.Log("  [stderr] " + res.Stderr)
+		}
+		if res.ExitCode != 0 {
+			t.Logger.Log(fmt.Sprintf("  exit=%d", res.ExitCode))
+			failed++
+		}
+	}
+	if failed > 0 {
+		return fmt.Errorf("WinRS: %d/%d host lỗi", failed, len(hosts))
+	}
+	t.Logger.Log(fmt.Sprintf("WinRS: %d host OK", len(hosts)))
+	return nil
+}
+
+func (t *WinRSApp) readScript() (string, error) {
+	if t.Template.Playbook == "" {
+		return "", fmt.Errorf("template WinRS chưa chọn script (playbook)")
+	}
+	p := filepath.Join(t.Repository.GetFullPath(t.Template.ID), t.Template.Playbook)
+	b, err := os.ReadFile(p)
+	if err != nil {
+		return "", fmt.Errorf("đọc script %s: %w", t.Template.Playbook, err)
+	}
+	return string(b), nil
+}
+
+// encodePowerShell mã hóa script → base64(UTF-16LE) cho `powershell -EncodedCommand`
+// (chuẩn PowerShell, xử lý được script nhiều dòng / ký tự đặc biệt).
+func encodePowerShell(script string) string {
+	u := utf16.Encode([]rune(script))
+	buf := make([]byte, len(u)*2)
+	for i, r := range u {
+		buf[i*2] = byte(r)
+		buf[i*2+1] = byte(r >> 8)
+	}
+	return base64.StdEncoding.EncodeToString(buf)
+}
