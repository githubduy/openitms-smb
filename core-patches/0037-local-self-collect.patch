# PATCH: 0037-local-self-collect
# WHY: Phan mem chay local nen inventory seed "May host (WinRS)" 127.0.0.1 (di vong WinRS toi loopback)
#      la thua. Server nen tu kiem ke truc tiep (local).
# WHAT: quickwin_seed.go bo seed inventory 127.0.0.1. DeviceInventory.vue +nut "Thu server nay (local)"
#       -> POST /collect {local:true} (plugin chay osquery local, khong WinRS/cert). +i18n devCollectLocal*.
# SPEC: docs/L2-specs/core-patches/0037-local-self-collect.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_seed.go b/api/projects/quickwin_seed.go
index a1a488b..b61c222 100644
--- a/api/projects/quickwin_seed.go
+++ b/api/projects/quickwin_seed.go
@@ -69,14 +69,9 @@ func SeedHostProjectIfEmpty(store db.Store, accessKeyService server.AccessKeySer
 
 	quickwinAutoRepo(store, project, noneKey.ID) // PATCH 0008 — repo Gitea local
 
-	if _, err = store.CreateInventory(db.Inventory{
-		Name:      "Máy host (WinRS)",
-		ProjectID: project.ID,
-		Type:      db.InventoryWinRS,
-		Inventory: "# Máy chính chạy OpenITMS. Đặt cert WinRM vào certs/host.pem rồi sửa dòng dưới.\n127.0.0.1 cert=host.pem",
-	}); err != nil {
-		log.WithError(err).Warn("QUICKWIN seed: tạo inventory WinRS thất bại")
-	}
+	// PATCH 0037 — KHÔNG seed inventory "Máy host (WinRS)" 127.0.0.1 nữa: phần mềm chạy ngay trên
+	// máy đó, đi vòng WinRS tới loopback là thừa. Server tự kiểm kê qua "Thu server này (local)"
+	// trong CMDB (plugin device-inventory). Máy remote thêm qua enroll/discovery.
 
 	log.WithField("project_id", project.ID).Info("QUICKWIN seed: đã tạo project Host mặc định")
 }
