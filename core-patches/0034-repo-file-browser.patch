@@ -105,6 +105,36 @@ func GetTemplateScriptFile(w http.ResponseWriter, r *http.Request) {
 	})
 }
 
+// ListTemplateRepoDir liệt kê nội dung 1 thư mục trong repo local (để duyệt chọn file).
+// GET ?repo_id=<id>&path=<dir> (path rỗng = gốc) → {local, path, entries:[{name,path,type}]}.
+func ListTemplateRepoDir(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	repoID := intFromQuery(r, "repo_id")
+	path := strings.Trim(strings.TrimSpace(r.URL.Query().Get("path")), "/")
+	if repoID == 0 {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]any{"error": "repo_id bắt buộc"})
+		return
+	}
+	ref, ok := resolveLocalGiteaRepo(helpers.Store(r), project, repoID)
+	if !ok {
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{"local": false})
+		return
+	}
+	ctx, cancel := context.WithTimeout(r.Context(), 15*time.Second)
+	defer cancel()
+	entries, err := giteaClientFor(ref).ListDir(ctx, ref.org, ref.repo, ref.branch, path)
+	if err != nil {
+		helpers.WriteError(w, err)
+		return
+	}
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"local":   true,
+		"path":    path,
+		"branch":  ref.branch,
+		"entries": entries,
+	})
+}
+
 // CommitTemplateScriptFile tạo/sửa file rồi commit vào repo local.
