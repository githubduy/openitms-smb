+# OpenITMS — collect Windows inventory, emit ONE compact JSON line (parsed by the server).
+# Chạy qua WinRS trên máy đã managed. Gọn + nhanh: CIM + registry uninstall + Net* cmdlets.
+$ErrorActionPreference = 'SilentlyContinue'
+$cs = Get-CimInstance Win32_ComputerSystem
+$os = Get-CimInstance Win32_OperatingSystem
+
+$sw = @()
+foreach ($k in 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*',
+               'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*') {
+  $sw += Get-ItemProperty $k | Where-Object { $_.DisplayName } |
+         Select-Object @{n='name';e={$_.DisplayName}}, @{n='version';e={$_.DisplayVersion}}
+}
+$sw = $sw | Sort-Object name -Unique
+
+[ordered]@{
+  hostname   = $env:COMPUTERNAME
+  domain     = $cs.Domain
+  workgroup  = -not $cs.PartOfDomain
+  os         = $os.Caption
+  os_version = $os.Version
+  ips        = @(Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -ne '127.0.0.1' } |
+                 Select-Object -ExpandProperty IPAddress)
+  dns        = @((Get-DnsClientServerAddress -AddressFamily IPv4).ServerAddresses | Select-Object -Unique)
+  gateway    = @((Get-NetRoute -DestinationPrefix '0.0.0.0/0').NextHop |
+                 Where-Object { $_ -and $_ -ne '0.0.0.0' } | Select-Object -Unique)
+  users      = @(Get-LocalUser | Select-Object @{n='name';e={$_.Name}}, @{n='enabled';e={[bool]$_.Enabled}})
+  groups     = @(Get-LocalGroup | Select-Object -ExpandProperty Name)
+  software   = @($sw)
+} | ConvertTo-Json -Depth 5 -Compress
