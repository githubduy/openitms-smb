# PATCH: 0025-winrs-inventory
# WHY: (A) Cần cảnh báo rõ rủi ro nếu file .pem (cert+key) bị lộ — nó là credential admin toàn fleet.
#      (B) Máy đã managed nên có tuỳ chọn (mặc định BẬT) thu thập inventory: software/IP/DNS/route/
#      hostname/user-group/domain.
# WHAT: scripts/collect-inventory.ps1 MỚI (CIM+registry+Net* → 1 dòng JSON gọn). quickwin_winrs_inventory.go
#       MỚI — chạy script qua winrsexec, parse JSON, lưu file (winrs-inventory dir); Get/SetConfig/Collect.
#       router +3 route. UI WinRSConsole: panel cảnh báo bảo mật .pem (i18n) + section Inventory (toggle
#       mặc định bật + nút Collect + hiển thị software/network/users/groups per host).
# SPEC: docs/L2-specs/core-patches/0025-winrs-inventory.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_winrs_inventory.go b/api/projects/quickwin_winrs_inventory.go
new file mode 100644
index 0000000..7cc3b71
--- /dev/null
+++ b/api/projects/quickwin_winrs_inventory.go
@@ -0,0 +1,160 @@
+// QUICKWIN PATCH 0025 — thu thập inventory máy Windows đã managed qua WinRS.
+// Chạy collect-inventory.ps1 (embed) trên host → parse JSON (software/IP/DNS/route/hostname/
+// user/group/domain) → lưu file (winrs-inventory dir). Tuỳ chọn bật/tắt (mặc định BẬT).
+// Spec: docs/L2-specs/core-patches/0025-winrs-inventory.md
+package projects
+
+import (
+	"context"
+	_ "embed"
+	"encoding/json"
+	"fmt"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+	"time"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+
+	"quickwin.dev/winrsexec"
+)
+
+//go:embed scripts/collect-inventory.ps1
+var collectInventoryScript string
+
+type winrsInvHost struct {
+	TS   int64           `json:"ts"`
+	Data json.RawMessage `json:"data"`
+}
+
+type winrsInvStore struct {
+	Enabled *bool                   `json:"enabled,omitempty"` // mặc định true
+	Hosts   map[string]winrsInvHost `json:"hosts"`
+}
+
+func winrsInvDir() string {
+	d := os.Getenv("QUICKWIN_DISCOVERY_DIR") // dùng chung dir dữ liệu runtime
+	if d == "" {
+		d = "discovery"
+	}
+	return d
+}
+
+func winrsInvFile(projectID int) string {
+	return filepath.Join(winrsInvDir(), fmt.Sprintf("inventory_%d.json", projectID))
+}
+
+func loadWinrsInv(projectID int) winrsInvStore {
+	s := winrsInvStore{Hosts: map[string]winrsInvHost{}}
+	if b, err := os.ReadFile(winrsInvFile(projectID)); err == nil {
+		_ = json.Unmarshal(b, &s)
+	}
+	if s.Hosts == nil {
+		s.Hosts = map[string]winrsInvHost{}
+	}
+	return s
+}
+
+func saveWinrsInv(projectID int, s winrsInvStore) {
+	_ = os.MkdirAll(winrsInvDir(), 0755)
+	b, _ := json.MarshalIndent(s, "", "  ")
+	_ = os.WriteFile(winrsInvFile(projectID), b, 0600)
+}
+
+// GetWinRSInventory trả cấu hình (enabled) + inventory đã thu thập của project.
+func GetWinRSInventory(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	s := loadWinrsInv(project.ID)
+	enabled := s.Enabled == nil || *s.Enabled
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"enabled": enabled, "hosts": s.Hosts})
+}
+
+type winrsInvConfigReq struct {
+	Enabled bool `json:"enabled"`
+}
+
+// SetWinRSInventoryConfig bật/tắt thu thập inventory (mặc định bật).
+func SetWinRSInventoryConfig(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req winrsInvConfigReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	s := loadWinrsInv(project.ID)
+	s.Enabled = &req.Enabled
+	saveWinrsInv(project.ID, s)
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"enabled": req.Enabled})
+}
+
+type winrsInvCollectReq struct {
+	Host string `json:"host"`
+	Port int    `json:"port"`
+	Cert string `json:"cert"`
+	Key  string `json:"key"`
+}
+
+// WinRSInventoryCollect chạy script collect trên 1 host → parse JSON → lưu.
+func WinRSInventoryCollect(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req winrsInvCollectReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	req.Host = strings.TrimSpace(req.Host)
+	req.Cert = strings.TrimSpace(req.Cert)
+	if req.Host == "" || req.Cert == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "host, cert bắt buộc"})
+		return
+	}
+	if strings.ContainsAny(req.Cert, "/\\") || strings.ContainsAny(req.Key, "/\\") {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "cert/key phải là tên file"})
+		return
+	}
+
+	dir := winrsCertsDir()
+	certPEM, err := os.ReadFile(filepath.Join(dir, req.Cert))
+	if err != nil {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "không đọc được cert: " + err.Error()})
+		return
+	}
+	keyPEM := certPEM
+	if req.Key != "" {
+		if kp, kerr := os.ReadFile(filepath.Join(dir, req.Key)); kerr == nil {
+			keyPEM = kp
+		}
+	}
+
+	ctx, cancel := context.WithTimeout(context.Background(), 120*time.Second)
+	defer cancel()
+	res, rerr := winrsexec.Run(ctx, winrsexec.Params{
+		Host: req.Host, Port: req.Port, CertPEM: certPEM, KeyPEM: keyPEM,
+		Command: "powershell -EncodedCommand " + encodePowerShellConsole(collectInventoryScript),
+		Timeout: 90 * time.Second,
+	})
+	if rerr != nil {
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{"ok": false, "error": winrsexec.Classify(rerr)})
+		return
+	}
+	out := strings.TrimSpace(res.Stdout)
+	if !json.Valid([]byte(out)) {
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{
+			"ok": false, "error": "output không phải JSON hợp lệ", "stderr": res.Stderr, "raw": firstN(out, 400),
+		})
+		return
+	}
+
+	s := loadWinrsInv(project.ID)
+	s.Hosts[req.Host] = winrsInvHost{TS: time.Now().Unix(), Data: json.RawMessage(out)}
+	saveWinrsInv(project.ID, s)
+
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"ok": true, "host": req.Host, "data": json.RawMessage(out)})
+}
+
+func firstN(s string, n int) string {
+	if len(s) > n {
+		return s[:n]
+	}
+	return s
+}
