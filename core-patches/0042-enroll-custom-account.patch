# PATCH: 0042-enroll-custom-account
# WHY: Enroll Windows dang luon tao account moi 'openitms'. Khach muon dung ACCOUNT CUSTOMER co san
#      -> can nhap account tren UI + regen script enroll theo account do.
# WHAT: winrs-enroll.ps1 +$CreateUser (inject @@ENROLL_USER@@/@@ENROLL_CREATE@@); create=0 -> dung
#       account co san (khong tao/doi mat khau, fail neu chua ton tai). GetEnrollScript doc ?user=&create=.
#       WinRSConsole.vue +o nhap account + checkbox "dung account co san" -> wire download + 1-click. +i18n.
# SPEC: docs/L2-specs/core-patches/0042-enroll-custom-account.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_enroll.go b/api/projects/quickwin_enroll.go
index c6f6908..f05a226 100644
--- a/api/projects/quickwin_enroll.go
+++ b/api/projects/quickwin_enroll.go
@@ -8,6 +8,7 @@ package projects
 import (
 	_ "embed"
 	"net/http"
+	"strings"
 
 	"github.com/gorilla/mux"
 )
@@ -36,7 +37,16 @@ func GetEnrollScript(w http.ResponseWriter, r *http.Request) {
 	// 1-click enrollment (PATCH 0016): nếu có ?server=&token= thì chèn vào script để tự upload cert.
 	server := r.URL.Query().Get("server")
 	token := r.URL.Query().Get("token")
-	content = enrollScriptInject(content, server, token)
+	// PATCH 0042 — account custom: ?user=<name>&create=<0|1>. Mặc định openitms + tạo mới.
+	user := strings.TrimSpace(r.URL.Query().Get("user"))
+	if user == "" {
+		user = "openitms"
+	}
+	create := "1"
+	if r.URL.Query().Get("create") == "0" {
+		create = "0"
+	}
+	content = enrollScriptInject(content, server, token, user, create)
 
 	w.Header().Set("Content-Type", "text/plain; charset=utf-8")
 	w.Header().Set("Content-Disposition", "attachment; filename="+filename)
