 const enrollTokenPlaceholder = "@@ENROLL_TOKEN@@"
+const enrollUserPlaceholder = "@@ENROLL_USER@@"     // account map cert (0042)
+const enrollCreatePlaceholder = "@@ENROLL_CREATE@@" // "1"=tạo account, "0"=dùng account có sẵn
 
 func enrollHMACKey() ([]byte, error) {
 	if util.Config == nil || util.Config.CookieHash == "" {
@@ -207,9 +209,11 @@ func hasHostLine(inventory, host string) bool {
 	return false
 }
 
-// enrollScriptInject thay placeholder server/token vào script tải về (dùng bởi 0014 handler).
-func enrollScriptInject(content, server, token string) string {
+// enrollScriptInject thay placeholder server/token/user/create vào script tải về (0014/0016/0042).
+func enrollScriptInject(content, server, token, user, create string) string {
 	content = strings.ReplaceAll(content, enrollServerPlaceholder, server)
 	content = strings.ReplaceAll(content, enrollTokenPlaceholder, token)
+	content = strings.ReplaceAll(content, enrollUserPlaceholder, user)
+	content = strings.ReplaceAll(content, enrollCreatePlaceholder, create)
 	return content
 }
