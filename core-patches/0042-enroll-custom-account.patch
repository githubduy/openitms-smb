+# Account injected by OpenITMS (1-click / custom-account regen). Plain download keeps placeholders.
+$__InjUser   = "@@ENROLL_USER@@"
+$__InjCreate = "@@ENROLL_CREATE@@"
+if ($__InjUser -notmatch '^@@') { $User = $__InjUser }
+$CreateUser = $true
+if ($__InjCreate -eq '0') { $CreateUser = $false }   # dùng account khách có sẵn, không tạo/đổi mật khẩu
