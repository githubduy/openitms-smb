-  Set-LocalUser -Name $User -Password $secure
+if ($CreateUser) {
+  if ([string]::IsNullOrWhiteSpace($Password)) {
+    # Generate a strong random password (account is only used internally for cert-auth)
+    $bytes = New-Object 'System.Byte[]' 18
+    [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes)
+    $Password = ([Convert]::ToBase64String($bytes) -replace '[^A-Za-z0-9]','') + "Aa1!"
+  }
+  $secure = ConvertTo-SecureString $Password -AsPlainText -Force
+
+  Write-Host "==> 1/5  Create local account '$User'" -ForegroundColor Cyan
+  if (Get-LocalUser -Name $User -ErrorAction SilentlyContinue) {
+    Set-LocalUser -Name $User -Password $secure
+  } else {
+    New-LocalUser -Name $User -Password $secure -FullName "OpenITMS Agent" `
+      -Description "OpenITMS remote management" -PasswordNeverExpires | Out-Null
+  }
 } else {
-  New-LocalUser -Name $User -Password $secure -FullName "OpenITMS Agent" `
-    -Description "OpenITMS remote management" -PasswordNeverExpires | Out-Null
+  # Custom account: dùng account khách đã có, KHÔNG tạo mới / KHÔNG đổi mật khẩu.
+  Write-Host "==> 1/5  Use existing account '$User'" -ForegroundColor Cyan
+  if (-not (Get-LocalUser -Name $User -ErrorAction SilentlyContinue)) {
+    Fail "Account '$User' khong ton tai tren may nay. Tao account do truoc, hoac chon 'tao account moi'."
+  }
 }
