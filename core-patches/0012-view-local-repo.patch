# PATCH: 0012-view-local-repo
# WHY: Repo local (Gitea) của project (tạo bởi 0008) có token nhúng trong GitURL (secret) →
#      không hiện thẳng ra UI được. Người dùng cần link mở/xem repo local mỗi project (G-05).
# WHAT: api/projects/quickwin_gitea_view.go MỚI — GetProjectGiteaRepo: tìm repository local
#       (host khớp QUICKWIN_GITEA_ADDR hoặc tên chứa "Gitea"), STRIP token/userinfo khỏi URL,
#       trả {repo_id,name,branch,web_url}. router.go +route GET /gitea/repo. UI: Repositories.vue
#       thêm banner "Repo local (Gitea)" + nút "Mở trên Gitea" (link web_url, target _blank).
# SPEC: docs/L2-specs/core-patches/0012-view-local-repo.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_gitea_view.go b/api/projects/quickwin_gitea_view.go
new file mode 100644
index 0000000..c781c68
--- /dev/null
+++ b/api/projects/quickwin_gitea_view.go
@@ -0,0 +1,50 @@
+// QUICKWIN PATCH 0012 — xem repo local (Gitea) của project trong UI.
+// Repository local do 0008 tạo có token nhúng trong GitURL (secret) → handler này trả URL
+// browse ĐÃ BỎ token để UI hiện link mở repo trên Gitea. Không lộ token ra frontend.
+// Spec: docs/L2-specs/core-patches/0012-view-local-repo.md
+package projects
+
+import (
+	"net/http"
+	"net/url"
+	"os"
+	"strings"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+)
+
+// GetProjectGiteaRepo trả URL browse repo local (Gitea) của project (token đã strip),
+// hoặc {web_url:null} nếu project không có repo local.
+func GetProjectGiteaRepo(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	addr := os.Getenv("QUICKWIN_GITEA_ADDR")
+
+	repos, err := helpers.Store(r).GetRepositories(project.ID, db.RetrieveQueryParams{})
+	if err != nil {
+		helpers.WriteError(w, err)
+		return
+	}
+
+	for _, rp := range repos {
+		u, perr := url.Parse(rp.GitURL)
+		if perr != nil {
+			continue
+		}
+		isGitea := (addr != "" && u.Host == addr) || strings.Contains(rp.Name, "Gitea")
+		if !isGitea {
+			continue
+		}
+		u.User = nil // BỎ token/userinfo trước khi trả về frontend
+		web := strings.TrimSuffix(u.String(), ".git")
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{
+			"repo_id": rp.ID,
+			"name":    rp.Name,
+			"branch":  rp.GitBranch,
+			"web_url": web,
+		})
+		return
+	}
+
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"web_url": nil})
+}
