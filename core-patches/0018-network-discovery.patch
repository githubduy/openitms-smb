# PATCH: 0018-network-discovery
# WHY: Ngoài nhập subnet thủ công, cho phép AUTODISCOVERY — quét dãy mạng tìm IP online rồi phân
#      loại managed/unmanaged/exception/gateway. Mặc định mỗi project có subnet 192.168.0.0/16.
# WHAT: quickwin_discovery.go MỚI — scanner TCP-probe (bounded concurrency + deadline) quét CIDR;
#       phân loại theo inventory WinRS (managed) + exceptions + heuristic gateway (.1/.254); lưu
#       config JSON (discovery dir, không đổi schema DB); handlers Get/AddSubnet/RemoveSubnet/Scan/
#       SetDevice. router +5 route /discovery/*. UI NetworkDiscovery.vue (subnet CRUD + scan + bảng
#       device + legend + ignore) + route + nav "Network Discovery" + tooltip + i18n en.js.
# SPEC: docs/L2-specs/core-patches/0018-network-discovery.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_discovery.go b/api/projects/quickwin_discovery.go
new file mode 100644
index 0000000..944c8c8
--- /dev/null
+++ b/api/projects/quickwin_discovery.go
@@ -0,0 +1,364 @@
+// QUICKWIN PATCH 0018 — Network Autodiscovery.
+// Ngoài nhập subnet thủ công, cho phép QUÉT dãy mạng (CIDR): probe TCP các cổng phổ biến để
+// tìm IP đang online, rồi phân loại: managed (đã trong inventory WinRS), unmanaged (online chưa
+// quản lý), exception (bỏ qua), gateway (router, heuristic .1/.254). Mặc định mỗi project có sẵn
+// subnet 192.168.0.0/16. Cấu hình lưu file JSON (discovery dir), không cần đổi schema DB.
+// Spec: docs/L2-specs/core-patches/0018-network-discovery.md
+package projects
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"net"
+	"net/http"
+	"os"
+	"path/filepath"
+	"sort"
+	"strings"
+	"sync"
+	"time"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+
+	"quickwin.dev/winrsexec"
+)
+
+const defaultDiscoverySubnet = "192.168.0.0/16"
+
+// Cổng probe để xác định host online + gợi ý loại thiết bị.
+var discoveryPorts = []int{445, 3389, 22, 5985, 5986, 80, 443}
+
+const (
+	discoveryConcurrency = 256
+	discoveryDialTimeout = 300 * time.Millisecond
+	discoveryDeadline    = 60 * time.Second
+	discoveryMaxHosts    = 70000 // /16 ~ 65536; chặn dãy quá lớn
+)
+
+type discoveryDevice struct {
+	IP       string `json:"ip"`
+	Online   bool   `json:"online"`
+	Ports    []int  `json:"ports"`
+	Hostname string `json:"hostname,omitempty"`
+	Status   string `json:"status"` // managed | unmanaged | exception | gateway
+	Note     string `json:"note,omitempty"`
+}
+
+type discoveryScan struct {
+	TS        int64             `json:"ts"`
+	CIDR      string            `json:"cidr"`
+	Scanned   int               `json:"scanned"`
+	Total     int               `json:"total"`
+	Completed bool              `json:"completed"`
+	Devices   []discoveryDevice `json:"devices"`
+}
+
+type discoveryConfig struct {
+	Subnets    []string          `json:"subnets"`
+	Exceptions []string          `json:"exceptions"`
+	Notes      map[string]string `json:"notes,omitempty"`
+	LastScan   *discoveryScan    `json:"last_scan,omitempty"`
+}
+
+func discoveryDir() string {
+	d := os.Getenv("QUICKWIN_DISCOVERY_DIR")
+	if d == "" {
+		d = "discovery"
+	}
+	return d
+}
+
+func discoveryFile(projectID int) string {
+	return filepath.Join(discoveryDir(), fmt.Sprintf("project_%d.json", projectID))
+}
+
+func loadDiscovery(projectID int) discoveryConfig {
+	cfg := discoveryConfig{Subnets: []string{defaultDiscoverySubnet}, Notes: map[string]string{}}
+	data, err := os.ReadFile(discoveryFile(projectID))
+	if err == nil {
+		_ = json.Unmarshal(data, &cfg)
+	}
+	if cfg.Subnets == nil {
+		cfg.Subnets = []string{defaultDiscoverySubnet}
+	}
+	if cfg.Notes == nil {
+		cfg.Notes = map[string]string{}
+	}
+	if cfg.Exceptions == nil {
+		cfg.Exceptions = []string{}
+	}
+	return cfg
+}
+
+func saveDiscovery(projectID int, cfg discoveryConfig) error {
+	_ = os.MkdirAll(discoveryDir(), 0755)
+	b, err := json.MarshalIndent(cfg, "", "  ")
+	if err != nil {
+		return err
+	}
+	return os.WriteFile(discoveryFile(projectID), b, 0600)
+}
+
+// managedHosts trả set IP/host đã có trong inventory WinRS của project (đã "managed").
+func managedHosts(r *http.Request, projectID int) map[string]bool {
+	set := map[string]bool{}
+	invs, err := helpers.Store(r).GetInventories(projectID, db.RetrieveQueryParams{}, []db.InventoryType{db.InventoryWinRS})
+	if err != nil {
+		return set
+	}
+	for _, inv := range invs {
+		for _, h := range winrsexec.ParseHosts(inv.Inventory, "") {
+			set[h.Addr] = true
+		}
+	}
+	return set
+}
+
+func contains(list []string, v string) bool {
+	for _, x := range list {
+		if x == v {
+			return true
+		}
+	}
+	return false
+}
+
+// isGatewayGuess: heuristic router/gateway (octet cuối .1 hoặc .254).
+func isGatewayGuess(ip string) bool {
+	p := strings.Split(ip, ".")
+	if len(p) != 4 {
+		return false
+	}
+	return p[3] == "1" || p[3] == "254"
+}
+
+func incIP(ip net.IP) {
+	for i := len(ip) - 1; i >= 0; i-- {
+		ip[i]++
+		if ip[i] != 0 {
+			break
+		}
+	}
+}
+
+// probeHost dial vài cổng; online nếu bất kỳ cổng mở HOẶC bị refuse (host up, cổng đóng).
+func probeHost(ctx context.Context, ip string) discoveryDevice {
+	d := discoveryDevice{IP: ip}
+	for _, p := range discoveryPorts {
+		select {
+		case <-ctx.Done():
+			return d
+		default:
+		}
+		dialer := net.Dialer{Timeout: discoveryDialTimeout}
+		conn, err := dialer.DialContext(ctx, "tcp", net.JoinHostPort(ip, fmt.Sprint(p)))
+		if err == nil {
+			conn.Close()
+			d.Online = true
+			d.Ports = append(d.Ports, p)
+		} else if strings.Contains(err.Error(), "refused") {
+			d.Online = true // host phản hồi RST -> đang bật, cổng đóng
+		}
+	}
+	return d
+}
+
+// scanCIDR quét dãy mạng, trả các host online (bounded concurrency + deadline).
+func scanCIDR(cidr string) (*discoveryScan, error) {
+	ip, ipnet, err := net.ParseCIDR(cidr)
+	if err != nil {
+		return nil, fmt.Errorf("CIDR không hợp lệ: %s", cidr)
+	}
+
+	var hosts []string
+	cur := ip.Mask(ipnet.Mask)
+	for c := make(net.IP, len(cur)); ; {
+		copy(c, cur)
+		if !ipnet.Contains(c) {
+			break
+		}
+		hosts = append(hosts, c.String())
+		if len(hosts) > discoveryMaxHosts {
+			return nil, fmt.Errorf("dãy quá lớn (>%d host) — thu hẹp subnet", discoveryMaxHosts)
+		}
+		incIP(cur)
+	}
+	// Bỏ network + broadcast của /x (x<31)
+	ones, bits := ipnet.Mask.Size()
+	if bits-ones >= 2 && len(hosts) >= 2 {
+		hosts = hosts[1 : len(hosts)-1]
+	}
+
+	scan := &discoveryScan{CIDR: cidr, Total: len(hosts), TS: time.Now().Unix()}
+
+	ctx, cancel := context.WithTimeout(context.Background(), discoveryDeadline)
+	defer cancel()
+
+	sem := make(chan struct{}, discoveryConcurrency)
+	results := make([]discoveryDevice, len(hosts))
+	var wg sync.WaitGroup
+	var scanned int
+	var mu sync.Mutex
+
+	for i, h := range hosts {
+		if ctx.Err() != nil {
+			break // deadline: dừng phát thêm probe
+		}
+		wg.Add(1)
+		sem <- struct{}{}
+		go func(idx int, host string) {
+			defer wg.Done()
+			defer func() { <-sem }()
+			results[idx] = probeHost(ctx, host)
+			mu.Lock()
+			scanned++
+			mu.Unlock()
+		}(i, h)
+	}
+	wg.Wait()
+
+	scan.Scanned = scanned
+	scan.Completed = ctx.Err() == nil
+	for _, d := range results {
+		if d.Online {
+			scan.Devices = append(scan.Devices, d)
+		}
+	}
+	return scan, nil
+}
+
+// classify gán status cho mỗi device theo thứ tự ưu tiên exception > managed > gateway > unmanaged.
+func classify(scan *discoveryScan, cfg discoveryConfig, managed map[string]bool) {
+	for i := range scan.Devices {
+		ip := scan.Devices[i].IP
+		scan.Devices[i].Note = cfg.Notes[ip]
+		switch {
+		case contains(cfg.Exceptions, ip):
+			scan.Devices[i].Status = "exception"
+		case managed[ip]:
+			scan.Devices[i].Status = "managed"
+		case isGatewayGuess(ip):
+			scan.Devices[i].Status = "gateway"
+		default:
+			scan.Devices[i].Status = "unmanaged"
+		}
+	}
+}
+
+// ---- HTTP handlers ----
+
+// GetDiscovery trả cấu hình discovery (subnets, exceptions, lần quét gần nhất đã phân loại lại).
+func GetDiscovery(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	cfg := loadDiscovery(project.ID)
+	if cfg.LastScan != nil {
+		classify(cfg.LastScan, cfg, managedHosts(r, project.ID))
+	}
+	helpers.WriteJSON(w, http.StatusOK, cfg)
+}
+
+type subnetReq struct {
+	CIDR string `json:"cidr"`
+}
+
+// AddDiscoverySubnet thêm 1 subnet (validate CIDR).
+func AddDiscoverySubnet(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req subnetReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	req.CIDR = strings.TrimSpace(req.CIDR)
+	if _, _, err := net.ParseCIDR(req.CIDR); err != nil {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "CIDR không hợp lệ (vd 192.168.1.0/24)"})
+		return
+	}
+	cfg := loadDiscovery(project.ID)
+	if !contains(cfg.Subnets, req.CIDR) {
+		cfg.Subnets = append(cfg.Subnets, req.CIDR)
+		sort.Strings(cfg.Subnets)
+		_ = saveDiscovery(project.ID, cfg)
+	}
+	helpers.WriteJSON(w, http.StatusOK, cfg)
+}
+
+// RemoveDiscoverySubnet xoá 1 subnet.
+func RemoveDiscoverySubnet(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req subnetReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	cfg := loadDiscovery(project.ID)
+	out := cfg.Subnets[:0]
+	for _, s := range cfg.Subnets {
+		if s != req.CIDR {
+			out = append(out, s)
+		}
+	}
+	cfg.Subnets = out
+	_ = saveDiscovery(project.ID, cfg)
+	helpers.WriteJSON(w, http.StatusOK, cfg)
+}
+
+// ScanDiscovery quét 1 CIDR (đồng bộ, bounded) → phân loại → lưu last_scan.
+func ScanDiscovery(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req subnetReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	scan, err := scanCIDR(strings.TrimSpace(req.CIDR))
+	if err != nil {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": err.Error()})
+		return
+	}
+	cfg := loadDiscovery(project.ID)
+	classify(scan, cfg, managedHosts(r, project.ID))
+	cfg.LastScan = scan
+	_ = saveDiscovery(project.ID, cfg)
+	helpers.WriteJSON(w, http.StatusOK, scan)
+}
+
+type deviceReq struct {
+	IP     string `json:"ip"`
+	Status string `json:"status"` // "exception" để bỏ qua, "unmanaged" để bỏ exception
+	Note   string `json:"note"`
+}
+
+// SetDiscoveryDevice đánh dấu 1 IP là exception (bỏ qua) hoặc gỡ, + ghi chú.
+func SetDiscoveryDevice(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req deviceReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	req.IP = strings.TrimSpace(req.IP)
+	if req.IP == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "thiếu ip"})
+		return
+	}
+	cfg := loadDiscovery(project.ID)
+	// exception toggle
+	inExc := contains(cfg.Exceptions, req.IP)
+	if req.Status == "exception" && !inExc {
+		cfg.Exceptions = append(cfg.Exceptions, req.IP)
+	} else if req.Status != "exception" && inExc {
+		out := cfg.Exceptions[:0]
+		for _, x := range cfg.Exceptions {
+			if x != req.IP {
+				out = append(out, x)
+			}
+		}
+		cfg.Exceptions = out
+	}
+	if req.Note != "" {
+		cfg.Notes[req.IP] = req.Note
+	} else {
+		delete(cfg.Notes, req.IP)
+	}
+	_ = saveDiscovery(project.ID, cfg)
+	helpers.WriteJSON(w, http.StatusOK, cfg)
+}
