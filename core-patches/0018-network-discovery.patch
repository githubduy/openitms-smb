+<template xmlns:v-slot="http://www.w3.org/1999/XSL/Transform">
+  <div>
+    <v-toolbar flat>
+      <v-app-bar-nav-icon @click="showDrawer()"></v-app-bar-nav-icon>
+      <v-toolbar-title>
+        <v-icon color="primary" class="mr-2">mdi-lan</v-icon>
+        {{ $t('discoveryTitle') }}
+      </v-toolbar-title>
+    </v-toolbar>
+
+    <v-divider />
+
+    <div class="pa-4" style="max-width: 1100px; margin: auto;">
+      <v-alert type="info" dense text class="mb-4">{{ $t('discoveryHint') }}</v-alert>
+
+      <!-- Subnets -->
+      <div class="subtitle-2 mb-1">{{ $t('discoverySubnets') }}</div>
+      <div class="mb-2">
+        <v-chip
+          v-for="s in subnets"
+          :key="s"
+          class="mr-2 mb-2"
+          close
+          @click:close="removeSubnet(s)"
+        >
+          <v-icon left small @click.stop="startScan(s)">mdi-radar</v-icon>
+          {{ s }}
+        </v-chip>
+        <span v-if="subnets.length === 0" class="caption grey--text">—</span>
+      </div>
+      <v-row class="mb-2" no-gutters>
+        <v-col cols="6" sm="4">
+          <v-text-field
+            v-model.trim="newSubnet"
+            :placeholder="$t('discoveryAddSubnet')"
+            dense
+            outlined
+            hide-details
+            @keyup.enter="addSubnet"
+          ></v-text-field>
+        </v-col>
+        <v-col cols="auto" class="ml-2">
+          <v-btn :disabled="!newSubnet" @click="addSubnet" outlined>
+            <v-icon left>mdi-plus</v-icon>{{ $t('add') }}
+          </v-btn>
+        </v-col>
+      </v-row>
+
+      <v-divider class="my-4" />
+
+      <!-- Scan -->
+      <v-row no-gutters align="center">
+        <v-col cols="6" sm="4">
+          <v-text-field
+            v-model.trim="scanCidr"
+            label="CIDR"
+            placeholder="192.168.1.0/24"
+            dense
+            outlined
+            hide-details
+          ></v-text-field>
+        </v-col>
+        <v-col cols="auto" class="ml-2">
+          <v-btn
+            color="primary"
+            :loading="scanning"
+            :disabled="scanning || !scanCidr"
+            @click="scan"
+          >
+            <v-icon left>mdi-radar</v-icon>{{ $t('discoveryScan') }}
+          </v-btn>
+        </v-col>
+        <v-col cols="auto" class="ml-4 caption" v-if="lastScan">
+          {{ lastScan.scanned }}/{{ lastScan.total }} ·
+          <span :class="lastScan.completed ? 'success--text' : 'warning--text'">
+            {{ lastScan.completed ? $t('discoveryDone') : $t('discoveryPartial') }}
+          </span>
+        </v-col>
+      </v-row>
+      <div v-if="rangeWarn" class="caption warning--text mt-1">{{ $t('discoveryLargeWarn') }}</div>
+      <div v-if="errorMsg" class="caption error--text mt-1">{{ errorMsg }}</div>
+
+      <!-- Legend -->
+      <div class="mt-3 mb-2">
+        <v-chip x-small color="success" text-color="white" class="mr-1">
+          {{ $t('statusManaged') }}
+        </v-chip>
+        <v-chip x-small color="warning" text-color="white" class="mr-1">
+          {{ $t('statusUnmanaged') }}
+        </v-chip>
+        <v-chip x-small color="info" text-color="white" class="mr-1">
+          {{ $t('statusGateway') }}
+        </v-chip>
+        <v-chip x-small color="grey" text-color="white">{{ $t('statusException') }}</v-chip>
+      </div>
+
+      <!-- Results -->
+      <v-simple-table dense v-if="devices.length">
+        <template v-slot:default>
+          <thead>
+            <tr>
+              <th>IP</th>
+              <th>{{ $t('status') }}</th>
+              <th>{{ $t('discoveryPorts') }}</th>
+              <th>{{ $t('note') }}</th>
+              <th class="text-right">{{ $t('actions') }}</th>
+            </tr>
+          </thead>
+          <tbody>
+            <tr v-for="d in devices" :key="d.ip">
+              <td><code>{{ d.ip }}</code></td>
+              <td>
+                <v-chip x-small :color="statusColor(d.status)" text-color="white">
+                  {{ $t('status' + capitalize(d.status)) }}
+                </v-chip>
+              </td>
+              <td class="caption">{{ (d.ports || []).join(', ') }}</td>
+              <td class="caption">{{ d.note }}</td>
+              <td class="text-right">
+                <v-btn
+                  v-if="d.status !== 'exception'"
+                  x-small text
+                  @click="setException(d.ip, true)"
+                >{{ $t('discoveryIgnore') }}</v-btn>
+                <v-btn
+                  v-else
+                  x-small text color="primary"
+                  @click="setException(d.ip, false)"
+                >{{ $t('discoveryUnignore') }}</v-btn>
+              </td>
+            </tr>
+          </tbody>
+        </template>
+      </v-simple-table>
+      <div v-else class="caption grey--text mt-2">{{ $t('discoveryNoDevices') }}</div>
+    </div>
+  </div>
+</template>
+<script>
+/* eslint-disable import/no-extraneous-dependencies */
+import axios from 'axios';
+import EventBus from '@/event-bus';
+
+export default {
+  props: {
+    projectId: Number,
+  },
+
+  data() {
+    return {
+      subnets: [],
+      exceptions: [],
+      notes: {},
+      newSubnet: '',
+      scanCidr: '',
+      scanning: false,
+      lastScan: null,
+      devices: [],
+      errorMsg: null,
+    };
+  },
+
+  computed: {
+    rangeWarn() {
+      const m = /\/(\d+)$/.exec(this.scanCidr || '');
+      return m && Number(m[1]) < 23; // rộng hơn /23 (>512 host)
+    },
+  },
+
+  async created() {
+    await this.load();
+  },
+
+  methods: {
+    showDrawer() { EventBus.$emit('i-show-drawer'); },
+    capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; },
+    statusColor(s) {
+      return {
+        managed: 'success', unmanaged: 'warning', gateway: 'info', exception: 'grey',
+      }[s] || 'grey';
+    },
+
+    apply(cfg) {
+      this.subnets = cfg.subnets || [];
+      this.exceptions = cfg.exceptions || [];
+      this.notes = cfg.notes || {};
+      if (cfg.last_scan) {
+        this.lastScan = cfg.last_scan;
+        this.devices = cfg.last_scan.devices || [];
+        if (!this.scanCidr) this.scanCidr = cfg.last_scan.cidr;
+      }
+    },
+
+    async load() {
+      try {
+        const { data } = await axios.get(`/api/project/${this.projectId}/discovery`);
+        this.apply(data);
+        if (!this.scanCidr && this.subnets.length) this.scanCidr = this.subnets[0];
+      } catch (e) { this.errorMsg = e.message; }
+    },
+
+    async addSubnet() {
+      if (!this.newSubnet) return;
+      try {
+        const { data } = await axios.post(`/api/project/${this.projectId}/discovery/subnet`, { cidr: this.newSubnet });
+        this.apply(data);
+        this.newSubnet = '';
+      } catch (e) { this.errorMsg = e.response?.data?.error || e.message; }
+    },
+
+    async removeSubnet(cidr) {
+      const { data } = await axios.post(`/api/project/${this.projectId}/discovery/subnet/remove`, { cidr });
+      this.apply(data);
+    },
+
+    startScan(cidr) {
+      this.scanCidr = cidr;
+      this.scan();
+    },
+
+    async scan() {
+      if (!this.scanCidr) return;
+      this.scanning = true;
+      this.errorMsg = null;
+      try {
+        const { data } = await axios.post(`/api/project/${this.projectId}/discovery/scan`, { cidr: this.scanCidr });
+        this.lastScan = data;
+        this.devices = data.devices || [];
+      } catch (e) { this.errorMsg = e.response?.data?.error || e.message; }
+      this.scanning = false;
+    },
+
+    async setException(ip, on) {
+      const { data } = await axios.post(`/api/project/${this.projectId}/discovery/device`, {
+        ip, status: on ? 'exception' : 'unmanaged', note: this.notes[ip] || '',
+      });
+      this.exceptions = data.exceptions || [];
+      // cập nhật lại status hiển thị mà không cần quét lại
+      const d = this.devices.find((x) => x.ip === ip);
+      if (d) d.status = on ? 'exception' : 'unmanaged';
+    },
+  },
+};
+</script>
