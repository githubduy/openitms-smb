--- /dev/null
+++ b/api/projects/quickwin_gitea.go
@@ -0,0 +1,71 @@
+// QUICKWIN PATCH 0008 — auto-repo Gitea khi tạo project.
+// Khi tạo project mới, tự tạo repo local trên Gitea (ADR-0005) + đăng ký làm repository
+// của project → mỗi project có sẵn 1 git repo local, zero-config.
+// Non-fatal: Gitea chưa cấu hình / lỗi → chỉ log, KHÔNG chặn tạo project.
+// Spec: docs/L2-specs/core-patches/0008-gitea-autorepo.md
+package projects
+
+import (
+	"context"
+	"net/url"
+	"os"
+	"time"
+
+	log "github.com/sirupsen/logrus"
+
+	"github.com/semaphoreui/semaphore/db"
+
+	giteamanager "quickwin.dev/gitea-manager"
+)
+
+// quickwinAutoRepo tạo repo Gitea cho project + đăng ký repository (SSHKey None).
+func quickwinAutoRepo(store db.Store, project db.Project, noneKeyID int) {
+	addr := os.Getenv("QUICKWIN_GITEA_ADDR")
+	token := os.Getenv("QUICKWIN_GITEA_TOKEN")
+	if addr == "" || token == "" {
+		return // Gitea không cấu hình → bỏ qua (không phải mọi bản cài đều bật Gitea)
+	}
+	org := os.Getenv("QUICKWIN_GITEA_ORG")
+	if org == "" {
+		org = "openitms"
+	}
+
+	c := giteamanager.NewClient("http://"+addr, token)
+	ctx, cancel := context.WithTimeout(context.Background(), 15*time.Second)
+	defer cancel()
+
+	if err := c.EnsureOrg(ctx, org); err != nil {
+		log.WithError(err).Warn("quickwin: EnsureOrg Gitea fail — bỏ qua auto-repo")
+		return
+	}
+	slug := giteamanager.Slug(project.Name)
+	repo, err := c.CreateRepo(ctx, org, slug, true)
+	if err != nil {
+		log.WithError(err).Warn("quickwin: tạo repo Gitea fail — bỏ qua auto-repo")
+		return
+	}
+
+	// Semaphore clone bằng HTTP + token nhúng (SSHKey None). Token làm username.
+	gitURL := injectToken(repo.CloneURL, token)
+	if _, err := store.CreateRepository(db.Repository{
+		Name:      "Local (Gitea)",
+		ProjectID: project.ID,
+		GitURL:    gitURL,
+		GitBranch: "main",
+		SSHKeyID:  noneKeyID,
+	}); err != nil {
+		log.WithError(err).Warn("quickwin: đăng ký repository local fail")
+		return
+	}
+	log.Infof("quickwin: project %d → repo local Gitea %s", project.ID, repo.FullName)
+}
+
+// injectToken chèn token vào clone URL để clone HTTP không cần nhập mật khẩu.
+func injectToken(cloneURL, token string) string {
+	u, err := url.Parse(cloneURL)
+	if err != nil {
+		return cloneURL
+	}
+	u.User = url.User(token)
+	return u.String()
+}
