+<script>
+import axios from 'axios';
+import EventBus from '@/event-bus';
+import { getErrorMessage } from '@/lib/error';
+
+const API = '/api/plugins/device-inventory';
+
+export default {
+  data() {
+    return {
+      devices: [],
+      loading: false,
+      error: null,
+      detail: {
+        show: false, data: null, changes: [], tab: 0,
+      },
+      collect: {
+        show: false,
+        busy: false,
+        error: null,
+        form: {
+          host: '',
+          version: 'v2c',
+          community: 'public',
+          user: '',
+          auth_proto: 'SHA',
+          auth_pass: '',
+          priv_proto: 'AES',
+          priv_pass: '',
+        },
+      },
+    };
+  },
+
+  async created() {
+    await this.loadDevices();
+  },
+
+  methods: {
+    showDrawer() {
+      EventBus.$emit('i-show-drawer');
+    },
+
+    async loadDevices() {
+      this.loading = true;
+      this.error = null;
+      try {
+        const { data } = await axios.get(`${API}/devices`);
+        this.devices = data.devices || [];
+      } catch (err) {
+        this.error = getErrorMessage(err);
+      } finally {
+        this.loading = false;
+      }
+    },
+
+    async openDevice(id) {
+      this.detail.tab = 0;
+      this.detail.changes = [];
+      try {
+        const [d, c] = await Promise.all([
+          axios.get(`${API}/device`, { params: { id } }),
+          axios.get(`${API}/changes`, { params: { id } }),
+        ]);
+        this.detail.data = d.data;
+        this.detail.changes = c.data.changes || [];
+        this.detail.show = true;
+      } catch (err) {
+        this.error = getErrorMessage(err);
+      }
+    },
+
+    openCollect() {
+      this.collect.error = null;
+      this.collect.show = true;
+    },
+
+    async submitCollect() {
+      this.collect.busy = true;
+      this.collect.error = null;
+      try {
+        await axios.post(`${API}/collect-switch`, this.collect.form);
+        this.collect.show = false;
+        await this.loadDevices();
+      } catch (err) {
+        this.collect.error = getErrorMessage(err);
+      } finally {
+        this.collect.busy = false;
+      }
+    },
+  },
+};
+</script>
