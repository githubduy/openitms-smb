+// AddDiscoveryToInventory thêm danh sách IP (hoặc tất cả unmanaged) vào inventory WinRS.
+func AddDiscoveryToInventory(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req addInvReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	added := addHostsToWinRSInventory(helpers.Store(r), project.ID, req.IPs)
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"added": added})
+}
+
+// RunDueScans (gọi từ scheduler cli/cmd) — quét định kỳ project nào bật auto_scan + tới hạn.
+func RunDueScans(store db.Store) {
+	projects, err := store.GetAllProjects()
+	if err != nil {
+		return
+	}
+	now := time.Now().Unix()
+	for _, p := range projects {
+		cfg := loadDiscovery(p.ID)
+		if !cfg.AutoScan || cfg.ScanInterval <= 0 || len(cfg.Subnets) == 0 {
+			continue
+		}
+		if cfg.LastScan != nil && now-cfg.LastScan.TS < int64(cfg.ScanInterval)*60 {
+			continue // chưa tới hạn
+		}
+		scan, serr := scanCIDR(cfg.Subnets[0]) // quét subnet đầu (định kỳ nên đặt /24)
+		if serr != nil {
+			continue
+		}
+		classify(scan, cfg, managedHosts(store, p.ID))
+		if cfg.AutoAddWinRS {
+			autoAddReachable(store, p.ID, scan)
+		}
+		cfg.LastScan = scan
+		_ = saveDiscovery(p.ID, cfg)
+	}
+}
