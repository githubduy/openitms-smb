+// SetDiscoveryConfig lưu tuỳ chọn quét định kỳ + tự thêm WinRS.
+func SetDiscoveryConfig(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var req discoveryConfigReq
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+	cfg := loadDiscovery(project.ID)
+	cfg.AutoScan = req.AutoScan
+	cfg.ScanInterval = req.ScanInterval
+	cfg.AutoAddWinRS = req.AutoAddWinRS
+	_ = saveDiscovery(project.ID, cfg)
+	helpers.WriteJSON(w, http.StatusOK, cfg)
+}
+
