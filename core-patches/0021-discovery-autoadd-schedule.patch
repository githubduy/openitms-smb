+// winrsReachable thử kết nối WinRS bằng cert mặc định (lệnh hostname). true nếu chạy được.
+func winrsReachable(ip string, certPEM []byte) bool {
+	ctx, cancel := context.WithTimeout(context.Background(), 8*time.Second)
+	defer cancel()
+	res, err := winrsexec.Run(ctx, winrsexec.Params{
+		Host: ip, CertPEM: certPEM, KeyPEM: certPEM, Command: "hostname", Timeout: 6 * time.Second,
+	})
+	return err == nil && res.ExitCode == 0
+}
+
+// autoAddReachable: với mỗi device unmanaged có cổng WinRS mở, thử connect bằng cert mặc định;
+// máy nào OK → thêm vào inventory + đánh dấu managed. Trả số máy đã thêm.
+func autoAddReachable(store db.Store, projectID int, scan *discoveryScan) int {
+	defCert := os.Getenv("QUICKWIN_WINRS_DEFAULT_CERT")
+	if defCert == "" {
+		return 0
+	}
+	certPEM, err := os.ReadFile(filepath.Join(winrsCertsDir(), defCert))
+	if err != nil {
+		return 0
+	}
+	var reach []string
+	for i := range scan.Devices {
+		d := &scan.Devices[i]
+		if d.Status != "unmanaged" {
+			continue
+		}
+		hasWinRS := false
+		for _, p := range d.Ports {
+			if p == 5985 || p == 5986 {
+				hasWinRS = true
+			}
+		}
+		if hasWinRS && winrsReachable(d.IP, certPEM) {
+			reach = append(reach, d.IP)
+			d.Status = "managed"
+		}
+	}
+	if len(reach) > 0 {
+		addHostsToWinRSInventory(store, projectID, reach)
+	}
+	return len(reach)
+}
