+// addHostsToWinRSInventory thêm danh sách IP vào inventory WinRS của project (tạo nếu chưa có).
+// cert = QUICKWIN_WINRS_DEFAULT_CERT nếu có, ngược lại "<ip>.pem" (placeholder tới khi enroll).
+func addHostsToWinRSInventory(store db.Store, projectID int, ips []string) int {
+	if len(ips) == 0 {
+		return 0
+	}
+	defCert := os.Getenv("QUICKWIN_WINRS_DEFAULT_CERT")
+	invs, _ := store.GetInventories(projectID, db.RetrieveQueryParams{}, []db.InventoryType{db.InventoryWinRS})
+
+	var inv db.Inventory
+	if len(invs) > 0 {
+		inv = invs[0]
+	} else {
+		inv = db.Inventory{Name: "WinRS Endpoints", ProjectID: projectID, Type: db.InventoryWinRS}
+	}
+
+	existing := map[string]bool{}
+	for _, h := range winrsexec.ParseHosts(inv.Inventory, "") {
+		existing[h.Addr] = true
+	}
+	added := 0
+	body := inv.Inventory
+	for _, ip := range ips {
+		ip = strings.TrimSpace(ip)
+		if ip == "" || existing[ip] {
+			continue
+		}
+		cert := defCert
+		if cert == "" {
+			cert = safeCertName(ip) + ".pem"
+		}
+		if body != "" && !strings.HasSuffix(body, "\n") {
+			body += "\n"
+		}
+		body += fmt.Sprintf("%s cert=%s\n", ip, cert)
+		existing[ip] = true
+		added++
+	}
+	if added == 0 {
+		return 0
+	}
+	inv.Inventory = body
+	if inv.ID == 0 {
+		_, _ = store.CreateInventory(inv)
+	} else {
+		_ = store.UpdateInventory(inv)
+	}
+	return added
+}
