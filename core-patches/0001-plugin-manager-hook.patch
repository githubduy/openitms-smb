# PATCH: 0001-plugin-manager-hook
# WHY: Tính năng plugin (ADR-0001) cần 1 điểm hook DUY NHẤT trong core để (a) start
#      Plugin Manager lúc service lên và (b) mount API động /api/plugins/ TRÊN subrouter
#      đã qua middleware `authentication` — nhờ đó plugin thừa hưởng authn của Semaphore,
#      không tự mở cửa riêng. Toàn bộ logic nằm ở module ngoài cây upstream
#      (quickwin.dev/pluginmanager); nếu upstream đổi router, chỉ cần tìm lại chỗ tạo
#      `authenticatedAPI` (PathPrefix "api" + Use(...authentication)) và gọi lại
#      registerQuickwinPlugins(authenticatedAPI) ngay sau đó.
# WHAT: (1) file MỚI api/quickwin_plugins.go — keo: env QUICKWIN_PLUGINS_DIR (default
#      "plugins"), Scan+Start manager, map helpers user → pluginv1.Caller;
#      (2) api/router.go +1 dòng gọi registerQuickwinPlugins;
#      (3) go.mod +require/replace quickwin.dev/* (path tương đối); go.sum GENERATED —
#      conflict ở go.sum thì đừng đọc diff, chạy lại `go mod tidy` là xong.
# SPEC: docs/L2-specs/core-patches/0001-plugin-manager-hook.md
# BASELINE: v2.18.16
#
diff --git a/api/quickwin_plugins.go b/api/quickwin_plugins.go
new file mode 100644
index 0000000..98ce388
--- /dev/null
+++ b/api/quickwin_plugins.go
@@ -0,0 +1,60 @@
+// QUICKWIN PATCH 0001 — hook Plugin Manager vào core.
+// File này được thêm bởi core-patches/0001-plugin-manager-hook.patch.
+// Toàn bộ logic plugin nằm ở module ngoài cây upstream (quickwin.dev/pluginmanager);
+// file này chỉ là lớp keo: đọc config, start manager, map user Semaphore → Caller.
+// Spec: docs/L2-specs/core-patches/0001-plugin-manager-hook.md
+package api
+
+import (
+	"context"
+	"net/http"
+	"os"
+
+	"github.com/gorilla/mux"
+	log "github.com/sirupsen/logrus"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+
+	pluginmanager "quickwin.dev/pluginmanager"
+	pluginv1 "quickwin.dev/proto/quickwin/plugin/v1"
+)
+
+// registerQuickwinPlugins mount API động /api/plugins/... vào subrouter ĐÃ authenticate.
+// Không có thư mục plugins → manager chạy rỗng, core hoạt động bình thường.
+func registerQuickwinPlugins(authenticatedAPI *mux.Router) {
+	dir := os.Getenv("QUICKWIN_PLUGINS_DIR")
+	if dir == "" {
+		dir = "plugins"
+	}
+
+	mgr := pluginmanager.New(pluginmanager.Options{
+		Dir: dir,
+		// CoreVersion để trống: version string hiện tại (quickwin-dev-semX.Y.Z) chưa phải
+		// semver thuần → check min_core_version bật lại khi versioning release chuẩn hóa.
+		CoreVersion: "",
+	})
+	if err := mgr.Scan(); err != nil {
+		log.WithError(err).Error("quickwin: scan plugins fail — chạy không plugin")
+	}
+	if err := mgr.Start(context.Background()); err != nil {
+		log.WithError(err).Error("quickwin: một số plugin không start được (xem log trên)")
+	}
+
+	authenticatedAPI.PathPrefix("/plugins/").Handler(mgr.Handler(quickwinCaller))
+	log.Infof("quickwin: plugin manager mounted at api/plugins (dir=%s)", dir)
+}
+
+// quickwinCaller — map user Semaphore (middleware authentication đã xác thực) → Caller proto.
+func quickwinCaller(r *http.Request) *pluginv1.Caller {
+	v := helpers.GetFromContext(r, "user")
+	u, ok := v.(*db.User)
+	if !ok || u == nil {
+		return nil // handler trả 401
+	}
+	return &pluginv1.Caller{
+		UserId:   int64(u.ID),
+		Username: u.Username,
+		IsAdmin:  u.Admin,
+	}
+}
