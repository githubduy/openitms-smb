# PATCH: 0010-winrs-console
# WHY: Nhu cầu "gõ lệnh nhanh xuống 1 host Windows" mà không phải tạo template + inventory +
#      chạy task. Bổ sung cho engine 0009: console đồng bộ (nhập host/cert/lệnh → chạy → xem ngay).
# WHAT: api/projects/quickwin_winrs.go MỚI — GetWinRSCerts (list *.pem trong certs dir) +
#       WinRSExec (chạy 1 lệnh pwsh qua winrsexec.Run, cert-auth, chặn path-traversal cert/key,
#       trả stdout/stderr/exit_code). router.go +2 route (/winrs/certs GET, /winrs/exec POST) trên
#       projectUserAPI (gate CanManageProjectResources). UI: view WinRSConsole.vue + route
#       /project/:id/winrs_console + nav item "WinRS Console" (App.vue).
# SPEC: docs/L2-specs/core-patches/0010-winrs-console.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_winrs.go b/api/projects/quickwin_winrs.go
new file mode 100644
index 0000000..361b1cb
--- /dev/null
+++ b/api/projects/quickwin_winrs.go
@@ -0,0 +1,135 @@
+// QUICKWIN PATCH 0010 — WinRS Console: chạy 1 lệnh pwsh nhanh xuống 1 host Windows
+// (WinRM cert-auth) mà không cần tạo template/inventory. Đồng bộ (chờ kết quả), gate bằng
+// CanManageProjectResources (đăng ký ở projectUserAPI). Logic winrm dùng chung winrsexec.
+// Spec: docs/L2-specs/core-patches/0010-winrs-console.md
+package projects
+
+import (
+	"context"
+	"encoding/base64"
+	"net/http"
+	"os"
+	"path/filepath"
+	"sort"
+	"strings"
+	"time"
+	"unicode/utf16"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+
+	"quickwin.dev/winrsexec"
+)
+
+// encodePowerShellConsole: script → base64(UTF-16LE) cho `powershell -EncodedCommand`.
+func encodePowerShellConsole(script string) string {
+	u := utf16.Encode([]rune(script))
+	buf := make([]byte, len(u)*2)
+	for i, r := range u {
+		buf[i*2] = byte(r)
+		buf[i*2+1] = byte(r >> 8)
+	}
+	return base64.StdEncoding.EncodeToString(buf)
+}
+
+func winrsCertsDir() string {
+	d := os.Getenv("QUICKWIN_CERTS_DIR")
+	if d == "" {
+		d = "certs"
+	}
+	return d
+}
+
+// GetWinRSCerts liệt kê tên file cert (.pem) trong certs dir để UI console chọn.
+func GetWinRSCerts(w http.ResponseWriter, r *http.Request) {
+	dir := winrsCertsDir()
+	entries, err := os.ReadDir(dir)
+	certs := []string{}
+	if err == nil {
+		for _, e := range entries {
+			if e.IsDir() {
+				continue
+			}
+			name := e.Name()
+			if strings.HasSuffix(name, ".pem") || strings.HasSuffix(name, ".crt") {
+				certs = append(certs, name)
+			}
+		}
+	}
+	sort.Strings(certs)
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"certs": certs})
+}
+
+type winrsExecRequest struct {
+	Host    string `json:"host"`
+	Port    int    `json:"port"`
+	Cert    string `json:"cert"`
+	Key     string `json:"key"`
+	Command string `json:"command"`
+}
+
+// WinRSExec chạy 1 lệnh xuống 1 host Windows qua WinRM cert-auth, trả kết quả đồng bộ.
+func WinRSExec(w http.ResponseWriter, r *http.Request) {
+	var req winrsExecRequest
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+
+	req.Host = strings.TrimSpace(req.Host)
+	req.Cert = strings.TrimSpace(req.Cert)
+	req.Command = strings.TrimSpace(req.Command)
+	if req.Host == "" || req.Cert == "" || req.Command == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{
+			"error": "host, cert, command là bắt buộc",
+		})
+		return
+	}
+
+	// Chặn path traversal: cert/key chỉ là tên file trong certs dir.
+	if strings.ContainsAny(req.Cert, "/\\") || strings.ContainsAny(req.Key, "/\\") {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{
+			"error": "cert/key phải là tên file trong certs dir (không chứa / hoặc \\)",
+		})
+		return
+	}
+
+	dir := winrsCertsDir()
+	certPEM, err := os.ReadFile(filepath.Join(dir, req.Cert))
+	if err != nil {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{
+			"error": "không đọc được cert: " + err.Error(),
+		})
+		return
+	}
+	keyPEM := certPEM
+	if req.Key != "" {
+		if kp, kerr := os.ReadFile(filepath.Join(dir, req.Key)); kerr == nil {
+			keyPEM = kp
+		}
+	}
+
+	ctx, cancel := context.WithTimeout(context.Background(), 90*time.Second)
+	defer cancel()
+
+	res, rerr := winrsexec.Run(ctx, winrsexec.Params{
+		Host:    req.Host,
+		Port:    req.Port,
+		CertPEM: certPEM,
+		KeyPEM:  keyPEM,
+		Command: "powershell -EncodedCommand " + encodePowerShellConsole(req.Command),
+		Timeout: 60 * time.Second,
+	})
+	if rerr != nil {
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{
+			"ok":    false,
+			"error": winrsexec.Classify(rerr),
+		})
+		return
+	}
+
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"ok":        res.ExitCode == 0,
+		"exit_code": res.ExitCode,
+		"stdout":    res.Stdout,
+		"stderr":    res.Stderr,
+	})
+}
