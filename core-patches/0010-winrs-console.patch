diff --git a/web/src/views/project/WinRSConsole.vue b/web/src/views/project/WinRSConsole.vue
new file mode 100644
index 0000000..ac669ea
--- /dev/null
+++ b/web/src/views/project/WinRSConsole.vue
@@ -0,0 +1,197 @@
+<template xmlns:v-slot="http://www.w3.org/1999/XSL/Transform">
+  <div>
+    <v-toolbar flat>
+      <v-app-bar-nav-icon @click="showDrawer()"></v-app-bar-nav-icon>
+      <v-toolbar-title>
+        <v-icon color="#0078d4" class="mr-2">mdi-microsoft-windows</v-icon>
+        WinRS Console
+      </v-toolbar-title>
+    </v-toolbar>
+
+    <v-divider />
+
+    <div class="pa-4" style="max-width: 900px; margin: auto;">
+      <v-alert type="info" dense text class="mb-4">
+        Chạy nhanh 1 lệnh PowerShell xuống 1 host Windows qua WinRM (cert). Không lưu lịch sử —
+        dùng Task Template (app WinRS) nếu cần lịch sử/lịch chạy.
+      </v-alert>
+
+      <v-row>
+        <v-col cols="8">
+          <v-text-field
+            v-model.trim="host"
+            label="Host / IP"
+            placeholder="10.0.0.5 hoặc win-app.lab"
+            outlined
+            dense
+          ></v-text-field>
+        </v-col>
+        <v-col cols="4">
+          <v-text-field
+            v-model.number="port"
+            label="Port"
+            type="number"
+            placeholder="5986"
+            outlined
+            dense
+          ></v-text-field>
+        </v-col>
+      </v-row>
+
+      <v-autocomplete
+        v-model="cert"
+        :items="certs"
+        label="Certificate (trong certs dir)"
+        :no-data-text="certsLoaded ? 'Không có cert nào trong certs dir' : 'Đang tải...'"
+        outlined
+        dense
+      ></v-autocomplete>
+
+      <codemirror
+        class="WinRSConsoleEditor"
+        :style="{ border: '1px solid lightgray' }"
+        v-model="command"
+        :options="cmOptions"
+        placeholder="Get-Service | Where-Object Status -eq 'Running' | Select-Object -First 5"
+      />
+
+      <div class="mt-3">
+        <v-btn
+          color="primary"
+          :loading="running"
+          :disabled="running || !host || !cert || !command"
+          @click="run"
+        >
+          <v-icon left>mdi-play</v-icon>
+          Chạy
+        </v-btn>
+        <span v-if="lastExit !== null" class="ml-4">
+          <v-chip
+            small
+            :color="lastExit === 0 ? 'success' : 'error'"
+            text-color="white"
+          >exit {{ lastExit }}</v-chip>
+        </span>
+        <span v-if="errorMsg" class="ml-4 error--text">{{ errorMsg }}</span>
+      </div>
+
+      <div v-if="stdout || stderr" class="mt-4">
+        <div v-if="stdout">
+          <div class="caption grey--text">stdout</div>
+          <pre class="WinRSConsoleOut">{{ stdout }}</pre>
+        </div>
+        <div v-if="stderr" class="mt-2">
+          <div class="caption grey--text">stderr</div>
+          <pre class="WinRSConsoleOut WinRSConsoleErr">{{ stderr }}</pre>
+        </div>
+      </div>
+    </div>
+  </div>
+</template>
+<style>
+.WinRSConsoleEditor .CodeMirror {
+  height: 140px !important;
+}
+
+.WinRSConsoleOut {
+  background: #1e1e1e;
+  color: #d4d4d4;
+  padding: 12px;
+  border-radius: 4px;
+  overflow-x: auto;
+  white-space: pre-wrap;
+  word-break: break-all;
+  font-family: monospace;
+  font-size: 13px;
+}
+
+.WinRSConsoleErr {
+  color: #f48771;
+}
+</style>
+<script>
+/* eslint-disable import/no-extraneous-dependencies,import/extensions */
+import axios from 'axios';
+import { codemirror } from 'vue-codemirror';
+import 'codemirror/lib/codemirror.css';
+import 'codemirror/addon/display/placeholder.js';
+import EventBus from '@/event-bus';
+
+export default {
+  components: { codemirror },
+
+  props: {
+    projectId: Number,
+  },
+
+  data() {
+    return {
+      host: '',
+      port: 5986,
+      cert: null,
+      command: '',
+      certs: [],
+      certsLoaded: false,
+      running: false,
+      stdout: '',
+      stderr: '',
+      lastExit: null,
+      errorMsg: null,
+      cmOptions: {
+        tabSize: 2,
+        mode: 'text/plain',
+        lineNumbers: true,
+        line: true,
+      },
+    };
+  },
+
+  async created() {
+    await this.loadCerts();
+  },
+
+  methods: {
+    showDrawer() {
+      EventBus.$emit('i-show-drawer');
+    },
+
+    async loadCerts() {
+      try {
+        const { data } = await axios.get(`/api/project/${this.projectId}/winrs/certs`);
+        this.certs = data.certs || [];
+      } catch (e) {
+        this.certs = [];
+      } finally {
+        this.certsLoaded = true;
+      }
+    },
+
+    async run() {
+      this.running = true;
+      this.stdout = '';
+      this.stderr = '';
+      this.lastExit = null;
+      this.errorMsg = null;
+      try {
+        const { data } = await axios.post(`/api/project/${this.projectId}/winrs/exec`, {
+          host: this.host,
+          port: this.port || 5986,
+          cert: this.cert,
+          command: this.command,
+        });
+        if (data.error) {
+          this.errorMsg = data.error;
+        } else {
+          this.stdout = data.stdout || '';
+          this.stderr = data.stderr || '';
+          this.lastExit = data.exit_code;
+        }
+      } catch (e) {
+        this.errorMsg = e.response?.data?.error || e.message || 'Lỗi không xác định';
+      } finally {
+        this.running = false;
+      }
+    },
+  },
+};
+</script>
