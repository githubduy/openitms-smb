+# 1-click enrollment: khi tải script từ nút "Enroll 1-click", OpenITMS chèn 2 giá trị này.
+# Nếu tải script thường (không token), 2 dòng giữ nguyên placeholder → bỏ qua tự upload.
+$OpenITMSServer = "@@OPENITMS_SERVER@@"
+$EnrollToken    = "@@ENROLL_TOKEN@@"
+
 function Fail($msg) { Write-Host "LỖI: $msg" -ForegroundColor Red; exit 1 }
 
 # 0. Kiểm tra quyền Administrator
@@ -100,15 +105,42 @@ Remove-Item $pfxPath, $tmpCer -ErrorAction SilentlyContinue
 $ips = (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
         Where-Object { $_.IPAddress -notlike '169.*' -and $_.IPAddress -ne '127.0.0.1' } |
         Select-Object -ExpandProperty IPAddress) -join ', '
+$primaryIp = ($ips.Split(',')[0]).Trim()
+
+# ---- 1-click: tự nạp cert lên OpenITMS nếu có server + token ----
+$autoUploaded = $false
+if ($OpenITMSServer -and $OpenITMSServer -notmatch '@@' -and $EnrollToken -and $EnrollToken -notmatch '@@') {
+  Write-Host "==> Tự nạp cert lên OpenITMS ($OpenITMSServer)" -ForegroundColor Cyan
+  try {
+    # Chấp nhận cert self-signed của OpenITMS trên LAN (chỉ cho lần gọi này).
+    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }
+    try { [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.SecurityProtocolType]::Tls12 } catch {}
+    $body = @{ token = $EnrollToken; host = $primaryIp; name = "$($env:COMPUTERNAME).pem"; cert_pem = $pem } | ConvertTo-Json
+    $resp = Invoke-RestMethod -Method Post -Uri "$OpenITMSServer/api/enroll/winrs" `
+              -ContentType 'application/json; charset=utf-8' -Body $body -TimeoutSec 30
+    if ($resp.ok) {
+      Write-Host "    ✓ Đã nạp cert + thêm host $primaryIp vào inventory. XONG (1-click)!" -ForegroundColor Green
+      $autoUploaded = $true
+    } else {
+      Write-Host "    Server trả lỗi: $($resp.error)" -ForegroundColor Yellow
+    }
+  } catch {
+    Write-Host "    Không tự nạp được ($($_.Exception.Message)) — dùng cách thủ công bên dưới." -ForegroundColor Yellow
+  } finally {
+    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = $null
+  }
+}
 
 Write-Host ""
 Write-Host "================= HOÀN TẤT =================" -ForegroundColor Green
 Write-Host "File chứng chỉ (PEM): $OutFile"
 Write-Host "IP máy này         : $ips"
-Write-Host ""
-Write-Host "BƯỚC TIẾP THEO trên OpenITMS:" -ForegroundColor Yellow
-Write-Host "  1. Copy file PEM ở trên vào thư mục 'certs/' của máy chủ OpenITMS."
-Write-Host "  2. Inventory > New Inventory > WinRS Endpoints, thêm dòng:"
-Write-Host "         $($ips.Split(',')[0].Trim()) cert=$(Split-Path $OutFile -Leaf)"
-Write-Host "  3. Xong — chạy WinRS Console / tác vụ xuống máy này."
+if (-not $autoUploaded) {
+  Write-Host ""
+  Write-Host "BƯỚC TIẾP THEO trên OpenITMS (nạp cert thủ công):" -ForegroundColor Yellow
+  Write-Host "  1. Copy file PEM ở trên vào thư mục 'certs/' của máy chủ OpenITMS."
+  Write-Host "  2. Inventory > New Inventory > WinRS Endpoints, thêm dòng:"
+  Write-Host "         $primaryIp cert=$(Split-Path $OutFile -Leaf)"
+  Write-Host "  3. Xong — chạy WinRS Console / tác vụ xuống máy này."
+}
 Write-Host "==========================================="
