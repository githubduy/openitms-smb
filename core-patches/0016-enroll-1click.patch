diff --git a/api/projects/quickwin_enroll_token.go b/api/projects/quickwin_enroll_token.go
new file mode 100644
index 0000000..1189213
--- /dev/null
+++ b/api/projects/quickwin_enroll_token.go
@@ -0,0 +1,215 @@
+// QUICKWIN PATCH 0016 — enrollment 1-click: token ký HMAC + endpoint nhận cert từ máy đích.
+// Luồng: UI tạo enroll-token (ngắn hạn) → tải script nhúng token+server URL → chạy trên máy
+// Windows → script POST cert lên /api/enroll/winrs (auth bằng token) → server lưu cert vào
+// certs dir + thêm host vào inventory WinRS của project. Không cần copy cert thủ công.
+// Token STATELESS (HMAC-SHA256, key = Config.CookieHash) → không cần lưu, tự hết hạn.
+// Spec: docs/L2-specs/core-patches/0016-enroll-1click.md
+package projects
+
+import (
+	"crypto/hmac"
+	"crypto/sha256"
+	"encoding/base64"
+	"fmt"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+	"time"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+	"github.com/semaphoreui/semaphore/util"
+)
+
+const enrollTokenTTL = 30 * time.Minute
+const maxCertBytes = 64 * 1024
+
+// Placeholder trong script enroll để 0014 handler chèn server URL + token khi tải 1-click.
+const enrollServerPlaceholder = "@@OPENITMS_SERVER@@"
+const enrollTokenPlaceholder = "@@ENROLL_TOKEN@@"
+
+func enrollHMACKey() ([]byte, error) {
+	if util.Config == nil || util.Config.CookieHash == "" {
+		return nil, fmt.Errorf("server chưa cấu hình cookie_hash — không ký được enroll token")
+	}
+	k, err := base64.StdEncoding.DecodeString(util.Config.CookieHash)
+	if err != nil || len(k) == 0 {
+		return nil, fmt.Errorf("cookie_hash không hợp lệ")
+	}
+	return k, nil
+}
+
+// signEnrollToken tạo token "projectID:exp.base64(hmac)" ký bằng cookie_hash.
+func signEnrollToken(projectID int, exp int64) (string, error) {
+	key, err := enrollHMACKey()
+	if err != nil {
+		return "", err
+	}
+	msg := fmt.Sprintf("%d:%d", projectID, exp)
+	mac := hmac.New(sha256.New, key)
+	mac.Write([]byte(msg))
+	sig := base64.RawURLEncoding.EncodeToString(mac.Sum(nil))
+	return base64.RawURLEncoding.EncodeToString([]byte(msg)) + "." + sig, nil
+}
+
+// verifyEnrollToken kiểm tra chữ ký + hạn, trả projectID.
+func verifyEnrollToken(token string) (int, error) {
+	parts := strings.SplitN(token, ".", 2)
+	if len(parts) != 2 {
+		return 0, fmt.Errorf("token sai định dạng")
+	}
+	msgBytes, err := base64.RawURLEncoding.DecodeString(parts[0])
+	if err != nil {
+		return 0, fmt.Errorf("token sai")
+	}
+	key, err := enrollHMACKey()
+	if err != nil {
+		return 0, err
+	}
+	mac := hmac.New(sha256.New, key)
+	mac.Write(msgBytes)
+	want := base64.RawURLEncoding.EncodeToString(mac.Sum(nil))
+	if !hmac.Equal([]byte(want), []byte(parts[1])) {
+		return 0, fmt.Errorf("token không hợp lệ (chữ ký sai)")
+	}
+	var projectID int
+	var exp int64
+	if _, err := fmt.Sscanf(string(msgBytes), "%d:%d", &projectID, &exp); err != nil {
+		return 0, fmt.Errorf("token sai nội dung")
+	}
+	if time.Now().Unix() > exp {
+		return 0, fmt.Errorf("token đã hết hạn")
+	}
+	return projectID, nil
+}
+
+// GetEnrollToken (authed) trả token enrollment ngắn hạn cho project.
+func GetEnrollToken(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	exp := time.Now().Add(enrollTokenTTL).Unix()
+	token, err := signEnrollToken(project.ID, exp)
+	if err != nil {
+		helpers.WriteJSON(w, http.StatusServiceUnavailable, map[string]string{"error": err.Error()})
+		return
+	}
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"token":      token,
+		"expires_at": exp,
+	})
+}
+
+type enrollWinRSRequest struct {
+	Token   string `json:"token"`
+	Host    string `json:"host"`
+	Name    string `json:"name"`
+	CertPEM string `json:"cert_pem"`
+}
+
+// safeCertName lọc tên file cert: chỉ chữ/số/dấu chấm/gạch, tránh path traversal.
+func safeCertName(s string) string {
+	s = strings.TrimSpace(s)
+	var b strings.Builder
+	for _, c := range s {
+		if (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') ||
+			c == '.' || c == '-' || c == '_' {
+			b.WriteRune(c)
+		}
+	}
+	out := b.String()
+	out = strings.ReplaceAll(out, "..", ".")     // triệt tiêu mọi chuỗi ".." (dù đã bỏ dấu / \)
+	out = strings.TrimLeft(out, ".-_")           // bỏ ký tự đầu gây tên file lạ / file ẩn
+	return out
+}
+
+// EnrollWinRS (public, auth bằng token) nhận cert từ máy đích → lưu certs dir + thêm host
+// vào inventory WinRS của project.
+func EnrollWinRS(w http.ResponseWriter, r *http.Request) {
+	var req enrollWinRSRequest
+	if !helpers.Bind(w, r, &req) {
+		return
+	}
+
+	projectID, err := verifyEnrollToken(req.Token)
+	if err != nil {
+		helpers.WriteJSON(w, http.StatusUnauthorized, map[string]string{"error": err.Error()})
+		return
+	}
+
+	req.Host = strings.TrimSpace(req.Host)
+	if req.Host == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "thiếu host"})
+		return
+	}
+	if len(req.CertPEM) == 0 || len(req.CertPEM) > maxCertBytes ||
+		!strings.Contains(req.CertPEM, "-----BEGIN") {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]string{"error": "cert_pem không hợp lệ"})
+		return
+	}
+
+	name := safeCertName(req.Name)
+	if name == "" {
+		name = safeCertName(req.Host)
+	}
+	if name == "" {
+		name = "endpoint"
+	}
+	if !strings.HasSuffix(name, ".pem") {
+		name += ".pem"
+	}
+
+	dir := winrsCertsDir()
+	if err := os.MkdirAll(dir, 0755); err != nil {
+		helpers.WriteJSON(w, http.StatusInternalServerError, map[string]string{"error": "không tạo được certs dir"})
+		return
+	}
+	if err := os.WriteFile(filepath.Join(dir, name), []byte(req.CertPEM), 0600); err != nil {
+		helpers.WriteJSON(w, http.StatusInternalServerError, map[string]string{"error": "không lưu được cert"})
+		return
+	}
+
+	// Thêm host vào inventory WinRS của project (tạo mới nếu chưa có).
+	store := helpers.Store(r)
+	line := fmt.Sprintf("%s cert=%s", req.Host, name)
+	invs, err := store.GetInventories(projectID, db.RetrieveQueryParams{}, []db.InventoryType{db.InventoryWinRS})
+	if err == nil && len(invs) > 0 {
+		inv := invs[0]
+		if !strings.Contains(inv.Inventory, req.Host+" ") && !hasHostLine(inv.Inventory, req.Host) {
+			if inv.Inventory != "" && !strings.HasSuffix(inv.Inventory, "\n") {
+				inv.Inventory += "\n"
+			}
+			inv.Inventory += line + "\n"
+			_ = store.UpdateInventory(inv)
+		}
+	} else {
+		_, _ = store.CreateInventory(db.Inventory{
+			Name:      "WinRS Endpoints",
+			ProjectID: projectID,
+			Type:      db.InventoryWinRS,
+			Inventory: line + "\n",
+		})
+	}
+
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"ok":        true,
+		"cert_file": name,
+		"host":      req.Host,
+	})
+}
+
+func hasHostLine(inventory, host string) bool {
+	for _, ln := range strings.Split(inventory, "\n") {
+		f := strings.Fields(strings.TrimSpace(ln))
+		if len(f) > 0 && f[0] == host {
+			return true
+		}
+	}
+	return false
+}
+
+// enrollScriptInject thay placeholder server/token vào script tải về (dùng bởi 0014 handler).
+func enrollScriptInject(content, server, token string) string {
+	content = strings.ReplaceAll(content, enrollServerPlaceholder, server)
+	content = strings.ReplaceAll(content, enrollTokenPlaceholder, token)
+	return content
+}
