# PATCH: 0014-endpoint-enroll-script
# WHY: Người dùng cần cách CHUẨN BỊ máy Windows (bật WinRM+cert / OpenSSH) để OpenITMS quản lý —
#      trước đây phải tự làm thủ công. Cho tải script cài đặt endpoint ngay trên web UI (SMB-friendly).
# WHAT: api/projects/scripts/{winrs-enroll,ssh-enroll}.ps1 MỚI (bật WinRM HTTPS+cert / OpenSSH server,
#       xuất PEM + hướng dẫn nạp lên OpenITMS). api/projects/quickwin_enroll.go MỚI — GetEnrollScript
#       (go:embed 2 script, tải về theo {kind}=winrs|ssh). router.go +route GET /endpoint/enroll-script/{kind}.
#       UI: WinRSConsole.vue thêm panel "Tải script chuẩn bị endpoint" (2 nút); InventoryForm.vue thêm
#       link tải script ở editor WinRS.
# SPEC: docs/L2-specs/core-patches/0014-endpoint-enroll-script.md
# BASELINE: v2.18.16
#
diff --git a/api/projects/quickwin_enroll.go b/api/projects/quickwin_enroll.go
new file mode 100644
index 0000000..bc9b554
--- /dev/null
+++ b/api/projects/quickwin_enroll.go
@@ -0,0 +1,40 @@
+// QUICKWIN PATCH 0014 — tải script chuẩn bị endpoint (WinRS / SSH) từ web UI.
+// Người dùng (kể cả không chuyên) tải script về, chạy AS ADMIN trên máy Windows cần quản lý;
+// script bật WinRM+cert (hoặc OpenSSH) và xuất chứng chỉ để nạp lên OpenITMS.
+// Script nhúng vào binary qua go:embed (không phụ thuộc file ngoài lúc chạy).
+// Spec: docs/L2-specs/core-patches/0014-endpoint-enroll-script.md
+package projects
+
+import (
+	_ "embed"
+	"net/http"
+
+	"github.com/gorilla/mux"
+)
+
+//go:embed scripts/winrs-enroll.ps1
+var winrsEnrollScript string
+
+//go:embed scripts/ssh-enroll.ps1
+var sshEnrollScript string
+
+// GetEnrollScript trả script chuẩn bị endpoint theo {kind} = winrs | ssh (tải về dạng .ps1).
+func GetEnrollScript(w http.ResponseWriter, r *http.Request) {
+	kind := mux.Vars(r)["kind"]
+
+	var content, filename string
+	switch kind {
+	case "winrs":
+		content, filename = winrsEnrollScript, "openitms-winrs-enroll.ps1"
+	case "ssh":
+		content, filename = sshEnrollScript, "openitms-ssh-enroll.ps1"
+	default:
+		http.Error(w, "kind phải là 'winrs' hoặc 'ssh'", http.StatusBadRequest)
+		return
+	}
+
+	w.Header().Set("Content-Type", "text/plain; charset=utf-8")
+	w.Header().Set("Content-Disposition", "attachment; filename="+filename)
+	w.Header().Set("X-Content-Type-Options", "nosniff")
+	_, _ = w.Write([]byte(content))
+}
diff --git a/api/projects/scripts/ssh-enroll.ps1 b/api/projects/scripts/ssh-enroll.ps1
new file mode 100644
index 0000000..7bcb185
