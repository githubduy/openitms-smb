@@ -0,0 +1,81 @@
+# ============================================================================
+#  OpenITMS — Chuẩn bị máy Windows để quản lý từ xa qua SSH (OpenSSH Server)
+# ============================================================================
+#  Chạy TRÊN MÁY WINDOWS cần quản lý, trong PowerShell "Run as Administrator".
+#
+#  Nó sẽ:
+#    1. Cài + bật OpenSSH Server (dịch vụ sshd, cổng 22).
+#    2. Mở firewall cổng 22.
+#    3. Đặt PowerShell làm shell mặc định của SSH (để chạy pwsh từ xa).
+#    4. Thêm public key của OpenITMS vào authorized_keys (nếu bạn dán -PublicKey).
+#
+#  SAU KHI CHẠY XONG:
+#    - Nếu chưa dán key: copy public key của OpenITMS (Key Store) rồi chạy lại với
+#        -PublicKey "ssh-ed25519 AAAA... openitms"
+#    - Vào OpenITMS > Key Store: thêm private key tương ứng (loại SSH).
+#    - Inventory (Ansible/SSH) hoặc template: dùng IP máy này + key đó.
+#
+#  ⚠️  Bật SSH server là thay đổi bảo mật hệ thống. Chỉ chạy trên máy nội bộ bạn quản trị.
+# ============================================================================
+
+[CmdletBinding()]
+param(
+  [string]$PublicKey = "",
+  [string]$SshUser = ""   # để trống = user đang chạy script (Administrators dùng administrators_authorized_keys)
+)
+
+$ErrorActionPreference = "Stop"
+function Fail($m){ Write-Host "LỖI: $m" -ForegroundColor Red; exit 1 }
+
+$id = [Security.Principal.WindowsIdentity]::GetCurrent()
+if (-not (New-Object Security.Principal.WindowsPrincipal($id)).IsInRole(
+      [Security.Principal.WindowsBuiltInRole]::Administrator)) {
+  Fail "Hãy mở PowerShell bằng 'Run as Administrator' rồi chạy lại."
+}
+
+Write-Host "==> 1/4  Cài OpenSSH Server" -ForegroundColor Cyan
+$cap = Get-WindowsCapability -Online -Name OpenSSH.Server* -ErrorAction SilentlyContinue
+if ($cap -and $cap.State -ne 'Installed') {
+  Add-WindowsCapability -Online -Name $cap.Name | Out-Null
+}
+
+Write-Host "==> 2/4  Bật dịch vụ sshd + firewall" -ForegroundColor Cyan
+Set-Service -Name sshd -StartupType Automatic
+Start-Service sshd
+if (-not (Get-NetFirewallRule -Name "OpenSSH-Server-In-TCP" -ErrorAction SilentlyContinue)) {
+  New-NetFirewallRule -Name "OpenSSH-Server-In-TCP" -DisplayName "OpenSSH Server (OpenITMS)" `
+    -Enabled True -Direction Inbound -Protocol TCP -Action Allow -LocalPort 22 | Out-Null
+}
+
+Write-Host "==> 3/4  Đặt PowerShell làm shell mặc định của SSH" -ForegroundColor Cyan
+$pwsh = (Get-Command powershell.exe).Source
+New-ItemProperty -Path "HKLM:\SOFTWARE\OpenSSH" -Name DefaultShell `
+  -Value $pwsh -PropertyType String -Force | Out-Null
+
+Write-Host "==> 4/4  Cấu hình authorized_keys" -ForegroundColor Cyan
+if ([string]::IsNullOrWhiteSpace($PublicKey)) {
+  Write-Host "    (bỏ qua — chưa cung cấp -PublicKey)" -ForegroundColor Yellow
+} else {
+  $admins = "$env:ProgramData\ssh\administrators_authorized_keys"
+  Add-Content -Path $admins -Value $PublicKey -Encoding ascii
+  # Quyền chuẩn cho administrators_authorized_keys
+  icacls $admins /inheritance:r /grant "Administrators:F" /grant "SYSTEM:F" | Out-Null
+  Write-Host "    Đã thêm key vào $admins"
+}
+
+$ips = (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
+        Where-Object { $_.IPAddress -notlike '169.*' -and $_.IPAddress -ne '127.0.0.1' } |
+        Select-Object -ExpandProperty IPAddress) -join ', '
+
+Write-Host ""
+Write-Host "================= HOÀN TẤT =================" -ForegroundColor Green
+Write-Host "SSH server (sshd) đang chạy, cổng 22."
+Write-Host "IP máy này: $ips"
+Write-Host ""
+if ([string]::IsNullOrWhiteSpace($PublicKey)) {
+  Write-Host "CÒN LẠI: chạy lại với public key của OpenITMS:" -ForegroundColor Yellow
+  Write-Host '  .\openitms-ssh-enroll.ps1 -PublicKey "ssh-ed25519 AAAA... openitms"'
+} else {
+  Write-Host "BƯỚC TIẾP THEO: trên OpenITMS thêm private key (Key Store) + dùng IP máy này." -ForegroundColor Yellow
+}
+Write-Host "==========================================="
diff --git a/api/projects/scripts/winrs-enroll.ps1 b/api/projects/scripts/winrs-enroll.ps1
new file mode 100644
index 0000000..c6f339e
--- /dev/null
+++ b/api/projects/scripts/winrs-enroll.ps1
@@ -0,0 +1,114 @@
+# ============================================================================
+#  OpenITMS — Chuẩn bị máy Windows để quản lý từ xa qua WinRS (WinRM + chứng chỉ)
+# ============================================================================
+#  Chạy script này TRÊN MÁY WINDOWS bạn muốn quản lý, trong cửa sổ
+#  PowerShell "Run as Administrator".
+#
+#  Nó sẽ:
+#    1. Tạo 1 tài khoản cục bộ để OpenITMS đăng nhập (mặc định 'openitms').
+#    2. Tạo chứng chỉ (certificate) cho tài khoản đó.
+#    3. Bật WinRM qua HTTPS (cổng 5986) + cho phép đăng nhập bằng chứng chỉ.
+#    4. Xuất ra 1 file .pem (chứng chỉ + khóa) để bạn tải LÊN máy chủ OpenITMS.
+#
+#  SAU KHI CHẠY XONG:
+#    - Copy file PEM (đường dẫn in ở cuối) vào thư mục 'certs/' của máy chủ OpenITMS.
+#    - Vào OpenITMS > Inventory > tạo "WinRS Endpoints", thêm dòng:
+#          <IP-máy-này> cert=<tên-file.pem>
+#    - Xong! Có thể chạy tác vụ / WinRS Console xuống máy này.
+#
+#  ⚠️  Script thay đổi cấu hình bảo mật (WinRM listener, cert auth). Chỉ chạy trên
+#      máy trong mạng nội bộ mà bạn có quyền quản trị.
+# ============================================================================
+
+[CmdletBinding()]
+param(
+  [string]$User = "openitms",
+  [string]$Password = "",
+  [string]$OutFile = "$env:USERPROFILE\Desktop\openitms-$($env:COMPUTERNAME).pem"
+)
+
+$ErrorActionPreference = "Stop"
+
+function Fail($msg) { Write-Host "LỖI: $msg" -ForegroundColor Red; exit 1 }
+
+# 0. Kiểm tra quyền Administrator
+$id = [Security.Principal.WindowsIdentity]::GetCurrent()
+if (-not (New-Object Security.Principal.WindowsPrincipal($id)).IsInRole(
+      [Security.Principal.WindowsBuiltInRole]::Administrator)) {
+  Fail "Hãy mở PowerShell bằng 'Run as Administrator' rồi chạy lại."
+}
+
+if ([string]::IsNullOrWhiteSpace($Password)) {
+  # Sinh mật khẩu ngẫu nhiên mạnh (tài khoản chỉ dùng nội bộ cho cert-auth)
+  $bytes = New-Object 'System.Byte[]' 18
+  [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes)
+  $Password = ([Convert]::ToBase64String($bytes) -replace '[^A-Za-z0-9]','') + "Aa1!"
+}
+$secure = ConvertTo-SecureString $Password -AsPlainText -Force
+
+Write-Host "==> 1/5  Tạo tài khoản cục bộ '$User'" -ForegroundColor Cyan
+if (Get-LocalUser -Name $User -ErrorAction SilentlyContinue) {
+  Set-LocalUser -Name $User -Password $secure
+} else {
+  New-LocalUser -Name $User -Password $secure -FullName "OpenITMS Agent" `
+    -Description "Tài khoản OpenITMS quản lý từ xa" -PasswordNeverExpires | Out-Null
+}
+Add-LocalGroupMember -Group "Administrators" -Member $User -ErrorAction SilentlyContinue
+
+Write-Host "==> 2/5  Tạo chứng chỉ cho '$User'" -ForegroundColor Cyan
+$clientCert = New-SelfSignedCertificate `
+  -Type Custom -KeyUsage DigitalSignature -KeySpec Signature `
+  -Subject "CN=$User" `
+  -TextExtension @("2.5.29.37={text}1.3.6.1.5.5.7.3.2", "2.5.29.17={text}upn=$User@localhost") `
+  -CertStoreLocation "Cert:\CurrentUser\My"
+
+$serverCert = New-SelfSignedCertificate -DnsName $env:COMPUTERNAME, "localhost" `
+  -CertStoreLocation "Cert:\LocalMachine\My"
+
+Write-Host "==> 3/5  Tin cậy chứng chỉ (Root + TrustedPeople)" -ForegroundColor Cyan
+$tmpCer = Join-Path $env:TEMP "openitms-client.cer"
+Export-Certificate -Cert $clientCert -FilePath $tmpCer | Out-Null
+Import-Certificate -FilePath $tmpCer -CertStoreLocation "Cert:\LocalMachine\Root" | Out-Null
+Import-Certificate -FilePath $tmpCer -CertStoreLocation "Cert:\LocalMachine\TrustedPeople" | Out-Null
+
+Write-Host "==> 4/5  Bật WinRM HTTPS (5986) + đăng nhập bằng chứng chỉ" -ForegroundColor Cyan
+if ((Get-Service WinRM).Status -ne 'Running') { Start-Service WinRM }
+Remove-WSManInstance winrm/config/Listener -SelectorSet @{Address="*";Transport="HTTPS"} -ErrorAction SilentlyContinue
+New-WSManInstance winrm/config/Listener -SelectorSet @{Address="*";Transport="HTTPS"} `
+  -ValueSet @{Hostname=$env:COMPUTERNAME;CertificateThumbprint=$serverCert.Thumbprint} | Out-Null
+Set-Item -Path WSMan:\localhost\Service\Auth\Certificate -Value $true
+New-NetFirewallRule -DisplayName "OpenITMS WinRM HTTPS 5986" -Direction Inbound `
+  -LocalPort 5986 -Protocol TCP -Action Allow -ErrorAction SilentlyContinue | Out-Null
+New-Item -Path WSMan:\localhost\ClientCertificate `
+  -Subject "$User@localhost" -URI * -Issuer $clientCert.Thumbprint `
+  -Credential (New-Object System.Management.Automation.PSCredential($User, $secure)) -Force | Out-Null
+
+Write-Host "==> 5/5  Xuất file PEM (chứng chỉ + khóa)" -ForegroundColor Cyan
+$pfxPath = Join-Path $env:TEMP "openitms-client.pfx"
+$pfxPass = ConvertTo-SecureString "pfx" -AsPlainText -Force
+Export-PfxCertificate -Cert $clientCert -FilePath $pfxPath -Password $pfxPass | Out-Null
+$col = New-Object System.Security.Cryptography.X509Certificates.X509Certificate2Collection
+$col.Import($pfxPath, "pfx", "Exportable")
+$c = $col[0]
+$certB64 = [Convert]::ToBase64String($c.RawData, 'InsertLineBreaks')
+$keyB64  = [Convert]::ToBase64String($c.GetRSAPrivateKey().ExportPkcs8PrivateKey(), 'InsertLineBreaks')
+$pem = "-----BEGIN CERTIFICATE-----`n$certB64`n-----END CERTIFICATE-----`n" +
+       "-----BEGIN PRIVATE KEY-----`n$keyB64`n-----END PRIVATE KEY-----`n"
+Set-Content -Path $OutFile -Value $pem -Encoding ascii
+Remove-Item $pfxPath, $tmpCer -ErrorAction SilentlyContinue
+
+$ips = (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
+        Where-Object { $_.IPAddress -notlike '169.*' -and $_.IPAddress -ne '127.0.0.1' } |
+        Select-Object -ExpandProperty IPAddress) -join ', '
+
+Write-Host ""
+Write-Host "================= HOÀN TẤT =================" -ForegroundColor Green
+Write-Host "File chứng chỉ (PEM): $OutFile"
+Write-Host "IP máy này         : $ips"
+Write-Host ""
+Write-Host "BƯỚC TIẾP THEO trên OpenITMS:" -ForegroundColor Yellow
+Write-Host "  1. Copy file PEM ở trên vào thư mục 'certs/' của máy chủ OpenITMS."
+Write-Host "  2. Inventory > New Inventory > WinRS Endpoints, thêm dòng:"
+Write-Host "         $($ips.Split(',')[0].Trim()) cert=$(Split-Path $OutFile -Leaf)"
+Write-Host "  3. Xong — chạy WinRS Console / tác vụ xuống máy này."
+Write-Host "==========================================="
