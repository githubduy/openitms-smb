+// QUICKWIN PATCH 0029 — tạo/sửa script file trực tiếp trên UI → commit vào repo local (Gitea).
+// Template form cho phép "New file": mở editor, điền sample, Lưu → file được commit vào git.
+// Hook mỏng: logic thật (Gitea Contents API) nằm ở package giteamanager ngoài cây upstream.
+// Spec: docs/L2-specs/core-patches/0029-template-script-editor.md
+package projects
+
+import (
+	"context"
+	"encoding/json"
+	"net/http"
+	"net/url"
+	"os"
+	"strings"
+	"time"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+
+	giteamanager "quickwin.dev/gitea-manager"
+)
+
+// giteaRepoRef — thông tin đủ để gọi Gitea Contents API cho 1 repository local của project.
+type giteaRepoRef struct {
+	org    string
+	repo   string
+	branch string
+	token  string
+}
+
+// resolveLocalGiteaRepo tìm repository (theo id) của project, xác nhận là repo local Gitea,
+// và tách org/repo/branch/token từ GitURL. ok=false nếu không phải repo local Gitea.
+func resolveLocalGiteaRepo(store db.Store, project db.Project, repoID int) (giteaRepoRef, bool) {
+	addr := os.Getenv("QUICKWIN_GITEA_ADDR")
+	repos, err := store.GetRepositories(project.ID, db.RetrieveQueryParams{})
+	if err != nil {
+		return giteaRepoRef{}, false
+	}
+	for _, rp := range repos {
+		if rp.ID != repoID {
+			continue
+		}
+		u, perr := url.Parse(rp.GitURL)
+		if perr != nil {
+			return giteaRepoRef{}, false
+		}
+		isGitea := (addr != "" && u.Host == addr) || strings.Contains(rp.Name, "Gitea")
+		if !isGitea {
+			return giteaRepoRef{}, false
+		}
+		// path dạng /<org>/<repo>.git
+		parts := strings.Split(strings.Trim(u.Path, "/"), "/")
+		if len(parts) < 2 {
+			return giteaRepoRef{}, false
+		}
+		token := os.Getenv("QUICKWIN_GITEA_TOKEN")
+		if u.User != nil { // token nhúng trong GitURL (0008) — ưu tiên
+			token = u.User.Username()
+		}
+		branch := rp.GitBranch
+		if branch == "" {
+			branch = "main"
+		}
+		return giteaRepoRef{
+			org:    parts[0],
+			repo:   strings.TrimSuffix(parts[1], ".git"),
+			branch: branch,
+			token:  token,
+		}, true
+	}
+	return giteaRepoRef{}, false
+}
+
+func giteaClientFor(ref giteaRepoRef) *giteamanager.Client {
+	addr := os.Getenv("QUICKWIN_GITEA_ADDR")
+	return giteamanager.NewClient("http://"+addr, ref.token)
+}
+
+// GetTemplateScriptFile trả nội dung 1 file trong repo local để edit.
+// GET ?repo_id=<id>&path=<filename> → {exists, content}.
+func GetTemplateScriptFile(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	repoID := intFromQuery(r, "repo_id")
+	path := strings.TrimSpace(r.URL.Query().Get("path"))
+	if repoID == 0 || path == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]any{"error": "repo_id và path bắt buộc"})
+		return
+	}
+	ref, ok := resolveLocalGiteaRepo(helpers.Store(r), project, repoID)
+	if !ok {
+		helpers.WriteJSON(w, http.StatusOK, map[string]any{"local": false})
+		return
+	}
+	ctx, cancel := context.WithTimeout(r.Context(), 15*time.Second)
+	defer cancel()
+	content, _, exists, err := giteaClientFor(ref).GetFile(ctx, ref.org, ref.repo, ref.branch, path)
+	if err != nil {
+		helpers.WriteError(w, err)
+		return
+	}
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"local":   true,
+		"exists":  exists,
+		"content": content,
+		"branch":  ref.branch,
+	})
+}
+
+// CommitTemplateScriptFile tạo/sửa file rồi commit vào repo local.
+// POST {repository_id, filename, content, message?} → {ok, path, commit_url}.
+func CommitTemplateScriptFile(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	var body struct {
+		RepositoryID int    `json:"repository_id"`
+		Filename     string `json:"filename"`
+		Content      string `json:"content"`
+		Message      string `json:"message"`
+	}
+	if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]any{"error": "body không hợp lệ"})
+		return
+	}
+	body.Filename = strings.TrimSpace(strings.TrimLeft(body.Filename, "/"))
+	if body.RepositoryID == 0 || body.Filename == "" {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]any{"error": "repository_id và filename bắt buộc"})
+		return
+	}
+	ref, ok := resolveLocalGiteaRepo(helpers.Store(r), project, body.RepositoryID)
+	if !ok {
+		helpers.WriteJSON(w, http.StatusBadRequest, map[string]any{
+			"error": "repository không phải repo local (Gitea) — chỉ commit trực tiếp được vào repo local",
+		})
+		return
+	}
+	msg := strings.TrimSpace(body.Message)
+	if msg == "" {
+		msg = "Update " + body.Filename + " via OpenITMS"
+	}
+	ctx, cancel := context.WithTimeout(r.Context(), 20*time.Second)
+	defer cancel()
+	commitURL, err := giteaClientFor(ref).PutFile(ctx, ref.org, ref.repo, ref.branch, body.Filename, body.Content, msg)
+	if err != nil {
+		helpers.WriteError(w, err)
+		return
+	}
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{
+		"ok":         true,
+		"path":       body.Filename,
+		"branch":     ref.branch,
+		"commit_url": commitURL,
+	})
+}
+
+func intFromQuery(r *http.Request, key string) int {
+	var n int
+	for _, ch := range r.URL.Query().Get(key) {
+		if ch < '0' || ch > '9' {
+			return 0
+		}
+		n = n*10 + int(ch-'0')
+	}
+	return n
+}
