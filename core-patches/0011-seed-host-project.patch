+// QUICKWIN PATCH 0011 — seed project "Host" mặc định lần chạy đầu.
+// Mục tiêu: ngay sau khi cài, người dùng đã có sẵn 1 project quản trị chính máy host
+// (inventory WinRS trỏ localhost) — không phải tự tạo từ đầu. Chỉ seed khi CHƯA có project
+// nào (idempotent) và đã có ít nhất 1 user (setup xong). Gọi từ runService (cli/cmd).
+// Spec: docs/L2-specs/core-patches/0011-seed-host-project.md
+package projects
+
+import (
+	"github.com/semaphoreui/semaphore/db"
+	"github.com/semaphoreui/semaphore/services/server"
+	log "github.com/sirupsen/logrus"
+)
+
+// SeedHostProjectIfEmpty tạo project "Host" nếu hệ thống chưa có project nào.
+func SeedHostProjectIfEmpty(store db.Store, accessKeyService server.AccessKeyService) {
+	projects, err := store.GetAllProjects()
+	if err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: không đọc được danh sách project — bỏ qua")
+		return
+	}
+	if len(projects) > 0 {
+		return // đã có project → không seed
+	}
+
+	users, err := store.GetUsers(db.RetrieveQueryParams{})
+	if err != nil || len(users) == 0 {
+		return // setup chưa xong (chưa có user) → để lần sau
+	}
+	owner := users[0]
+	for i := range users {
+		if users[i].Admin {
+			owner = users[i]
+			break
+		}
+	}
+
+	project, err := store.CreateProject(db.Project{Name: "Host — máy chính OpenITMS"})
+	if err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: tạo project Host thất bại")
+		return
+	}
+
+	if _, err = store.CreateProjectUser(db.ProjectUser{
+		ProjectID: project.ID, UserID: owner.ID, Role: db.ProjectOwner,
+	}); err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: gán owner thất bại")
+		return
+	}
+
+	noneKey, err := accessKeyService.Create(db.AccessKey{
+		Name:      "None",
+		Type:      db.AccessKeyNone,
+		ProjectID: &project.ID,
+	})
+	if err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: tạo None key thất bại")
+		return
+	}
+
+	if _, err = store.CreateView(db.View{
+		ProjectID: project.ID,
+		Title:     "All",
+		Position:  0,
+		Type:      db.ViewTypeAll,
+	}); err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: tạo view thất bại")
+		return
+	}
+
+	quickwinAutoRepo(store, project, noneKey.ID) // PATCH 0008 — repo Gitea local
+
+	if _, err = store.CreateInventory(db.Inventory{
+		Name:      "Máy host (WinRS)",
+		ProjectID: project.ID,
+		Type:      db.InventoryWinRS,
+		Inventory: "# Máy chính chạy OpenITMS. Đặt cert WinRM vào certs/host.pem rồi sửa dòng dưới.\n127.0.0.1 cert=host.pem",
+	}); err != nil {
+		log.WithError(err).Warn("QUICKWIN seed: tạo inventory WinRS thất bại")
+	}
+
+	log.WithField("project_id", project.ID).Info("QUICKWIN seed: đã tạo project Host mặc định")
+}
