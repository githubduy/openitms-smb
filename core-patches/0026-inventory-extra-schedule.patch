+// collectHostInventory chạy script collect trên 1 host → JSON hợp lệ, hoặc lỗi.
+func collectHostInventory(host string, port int, certPEM, keyPEM []byte) (json.RawMessage, error) {
+	ctx, cancel := context.WithTimeout(context.Background(), 120*time.Second)
+	defer cancel()
+	res, err := winrsexec.Run(ctx, winrsexec.Params{
+		Host: host, Port: port, CertPEM: certPEM, KeyPEM: keyPEM,
+		Command: "powershell -EncodedCommand " + encodePowerShellConsole(collectInventoryScript),
+		Timeout: 100 * time.Second,
+	})
+	if err != nil {
+		return nil, fmt.Errorf("%s", winrsexec.Classify(err))
+	}
+	out := strings.TrimSpace(res.Stdout)
+	if !json.Valid([]byte(out)) {
+		return nil, fmt.Errorf("output không phải JSON hợp lệ")
+	}
+	return json.RawMessage(out), nil
+}
+
+// RunDueInventoryCollect (scheduler) — tự thu thập inventory mọi máy managed của project nào bật +
+// tới hạn (mặc định 4h). Đọc host+cert từ inventory WinRS.
+func RunDueInventoryCollect(store db.Store) {
+	projects, err := store.GetAllProjects()
+	if err != nil {
+		return
+	}
+	now := time.Now().Unix()
+	certDir := winrsCertsDir()
+	for _, p := range projects {
+		s := loadWinrsInv(p.ID)
+		if s.Enabled != nil && !*s.Enabled {
+			continue
+		}
+		if s.LastCollect > 0 && now-s.LastCollect < int64(s.interval())*60 {
+			continue // chưa tới hạn
+		}
+		invs, ierr := store.GetInventories(p.ID, db.RetrieveQueryParams{}, []db.InventoryType{db.InventoryWinRS})
+		if ierr != nil {
+			continue
+		}
+		for _, inv := range invs {
+			for _, h := range winrsexec.ParseHosts(inv.Inventory, "") {
+				if h.Cert == "" {
+					continue
+				}
+				certPEM, cerr := os.ReadFile(filepath.Join(certDir, h.Cert))
+				if cerr != nil {
+					continue
+				}
+				keyPEM := certPEM
+				if h.Key != "" {
+					if kp, kerr := os.ReadFile(filepath.Join(certDir, h.Key)); kerr == nil {
+						keyPEM = kp
+					}
+				}
+				data, derr := collectHostInventory(h.Addr, h.Port, certPEM, keyPEM)
+				if derr != nil {
+					continue // host offline / cert sai → bỏ qua
+				}
+				s.Hosts[h.Addr] = winrsInvHost{TS: now, Data: data}
+			}
+		}
+		s.LastCollect = now
+		saveWinrsInv(p.ID, s)
+	}
 }
 
