@@ -0,0 +1,81 @@
+// QUICKWIN PATCH 0017 — lịch sử chạy WinRS Console.
+// Mỗi lần gõ lệnh ở WinRS Console được ghi tạm ra file JSONL trong tmp dir của project
+// (chỉ metadata: thời gian/host/lệnh/exit — KHÔNG lưu stdout). Giữ 100 dòng gần nhất.
+// UI đọc lại để xem/lặp lệnh cũ. Client (localStorage) nhớ last-run + tự prefill.
+// Spec: docs/L2-specs/core-patches/0017-winrs-history.md
+package projects
+
+import (
+	"encoding/json"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/semaphoreui/semaphore/api/helpers"
+	"github.com/semaphoreui/semaphore/db"
+	"github.com/semaphoreui/semaphore/util"
+)
+
+const winrsHistoryMax = 100
+
+type winrsHistoryEntry struct {
+	TS       int64  `json:"ts"`
+	Host     string `json:"host"`
+	Command  string `json:"command"`
+	ExitCode int    `json:"exit_code"`
+	OK       bool   `json:"ok"`
+	Error    string `json:"error,omitempty"`
+}
+
+func winrsHistoryFile(projectID int) string {
+	dir := util.Config.GetProjectTmpDir(projectID)
+	return filepath.Join(dir, "winrs-history.jsonl")
+}
+
+// appendWinRSHistory ghi 1 entry, giữ tối đa winrsHistoryMax dòng (cắt cũ nhất).
+func appendWinRSHistory(projectID int, e winrsHistoryEntry) {
+	path := winrsHistoryFile(projectID)
+	_ = os.MkdirAll(filepath.Dir(path), 0755)
+
+	lines := readHistoryLines(path)
+	b, err := json.Marshal(e)
+	if err != nil {
+		return
+	}
+	lines = append(lines, string(b))
+	if len(lines) > winrsHistoryMax {
+		lines = lines[len(lines)-winrsHistoryMax:]
+	}
+	_ = os.WriteFile(path, []byte(strings.Join(lines, "\n")+"\n"), 0600)
+}
+
+func readHistoryLines(path string) []string {
+	data, err := os.ReadFile(path)
+	if err != nil {
+		return nil
+	}
+	var out []string
+	for _, ln := range strings.Split(string(data), "\n") {
+		if strings.TrimSpace(ln) != "" {
+			out = append(out, ln)
+		}
+	}
+	return out
+}
+
+// GetWinRSHistory trả lịch sử chạy WinRS Console của project (mới nhất trước).
+func GetWinRSHistory(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	lines := readHistoryLines(winrsHistoryFile(project.ID))
+
+	entries := make([]winrsHistoryEntry, 0, len(lines))
+	// đảo ngược: mới nhất lên đầu
+	for i := len(lines) - 1; i >= 0; i-- {
+		var e winrsHistoryEntry
+		if json.Unmarshal([]byte(lines[i]), &e) == nil {
+			entries = append(entries, e)
+		}
+	}
+	helpers.WriteJSON(w, http.StatusOK, map[string]any{"history": entries})
+}
