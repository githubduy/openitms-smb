@@ -370,6 +421,33 @@ export default {
         this.collect.busy = false;
       }
     },
+
+    async openCollectHost() {
+      this.host.error = null;
+      this.host.show = true;
+      // nạp danh sách cert từ core (thư mục ./certs của project).
+      try {
+        const pid = this.$route.params.projectId;
+        const { data } = await axios.get(`/api/project/${pid}/winrs/certs`);
+        this.host.certs = (data.certs || []).map((c) => c.name);
+      } catch (err) {
+        this.host.certs = [];
+      }
+    },
+
+    async submitCollectHost() {
+      this.host.busy = true;
+      this.host.error = null;
+      try {
+        await axios.post(`${API}/collect`, this.host.form);
+        this.host.show = false;
+        await this.loadDevices();
+      } catch (err) {
+        this.host.error = getErrorMessage(err);
+      } finally {
+        this.host.busy = false;
+      }
+    },
   },
 };
 </script>
