+
+    changes(h) {
+      const cur = h.data || {};
+      const prev = h.prev || {};
+      const names = (arr) => (arr || []).map((x) => x.name);
+      const curSw = names(cur.software);
+      const prevSw = names(prev.software);
+      const swAdded = curSw.filter((n) => !prevSw.includes(n));
+      const swRemoved = prevSw.filter((n) => !curSw.includes(n));
+      const prevState = {};
+      (prev.services || []).forEach((s) => { prevState[s.name] = s.state; });
+      const svc = (cur.services || [])
+        .filter((s) => prevState[s.name] !== undefined && prevState[s.name] !== s.state)
+        .map((s) => ({ name: s.name, from: prevState[s.name], to: s.state }));
+      return { swAdded, swRemoved, svc };
