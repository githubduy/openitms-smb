+	Data   json.RawMessage `json:"data"`
+	PrevTS int64           `json:"prev_ts,omitempty"` // lần quét trước (để so sánh thay đổi)
+	Prev   json.RawMessage `json:"prev,omitempty"`
+}
+
+// setHostData lưu data mới, chuyển data cũ sang prev (giữ 1 mốc để so sánh).
+func (s *winrsInvStore) setHostData(host string, data json.RawMessage, ts int64) {
+	old := s.Hosts[host]
+	h := winrsInvHost{TS: ts, Data: data}
+	if len(old.Data) > 0 {
+		h.PrevTS = old.TS
+		h.Prev = old.Data
+	}
+	s.Hosts[host] = h
 }
 
 const defaultInvIntervalMin = 240 // 4h
@@ -143,7 +158,7 @@ func RunDueInventoryCollect(store db.Store) {
 				if derr != nil {
 					continue // host offline / cert sai → bỏ qua
 				}
-				s.Hosts[h.Addr] = winrsInvHost{TS: now, Data: data}
+				s.setHostData(h.Addr, data, now)
 			}
 		}
 		s.LastCollect = now
@@ -217,8 +232,66 @@ func WinRSInventoryCollect(w http.ResponseWriter, r *http.Request) {
 	}
 
 	s := loadWinrsInv(project.ID)
-	s.Hosts[req.Host] = winrsInvHost{TS: time.Now().Unix(), Data: data}
+	s.setHostData(req.Host, data, time.Now().Unix())
 	saveWinrsInv(project.ID, s)
 
 	helpers.WriteJSON(w, http.StatusOK, map[string]any{"ok": true, "host": req.Host, "data": data})
 }
+
+type invDataSummary struct {
+	Hostname string   `json:"hostname"`
+	Domain   string   `json:"domain"`
+	OS       string   `json:"os"`
+	OSBuild  string   `json:"os_build"`
+	IPs      []string `json:"ips"`
+	DNS      []string `json:"dns"`
+	Gateway  []string `json:"gateway"`
+	Users    []struct {
+		Name string `json:"name"`
+	} `json:"users"`
+	Groups   []string          `json:"groups"`
+	Software []json.RawMessage `json:"software"`
+	Services []json.RawMessage `json:"services"`
+	Tasks    []json.RawMessage `json:"tasks"`
+	Hotfixes []json.RawMessage `json:"hotfixes"`
+}
+
+// ExportWinRSInventory tải inventory toàn fleet: ?format=json (raw) hoặc csv (1 dòng/host, tóm tắt).
+func ExportWinRSInventory(w http.ResponseWriter, r *http.Request) {
+	project := helpers.GetFromContext(r, "project").(db.Project)
+	s := loadWinrsInv(project.ID)
+
+	if r.URL.Query().Get("format") == "json" {
+		w.Header().Set("Content-Type", "application/json; charset=utf-8")
+		w.Header().Set("Content-Disposition", "attachment; filename=inventory.json")
+		_ = json.NewEncoder(w).Encode(s.Hosts)
+		return
+	}
+
+	ips := make([]string, 0, len(s.Hosts))
+	for ip := range s.Hosts {
+		ips = append(ips, ip)
+	}
+	sort.Strings(ips)
+
+	w.Header().Set("Content-Type", "text/csv; charset=utf-8")
+	w.Header().Set("Content-Disposition", "attachment; filename=inventory.csv")
+	cw := csv.NewWriter(w)
+	_ = cw.Write([]string{
+		"ip", "hostname", "domain", "os", "os_build", "ips", "dns", "gateway",
+		"users", "groups", "software", "services", "tasks", "hotfixes", "collected",
+	})
+	for _, ip := range ips {
+		h := s.Hosts[ip]
+		var d invDataSummary
+		_ = json.Unmarshal(h.Data, &d)
+		_ = cw.Write([]string{
+			ip, d.Hostname, d.Domain, d.OS, d.OSBuild,
+			strings.Join(d.IPs, " "), strings.Join(d.DNS, " "), strings.Join(d.Gateway, " "),
+			fmt.Sprint(len(d.Users)), fmt.Sprint(len(d.Groups)), fmt.Sprint(len(d.Software)),
+			fmt.Sprint(len(d.Services)), fmt.Sprint(len(d.Tasks)), fmt.Sprint(len(d.Hotfixes)),
+			time.Unix(h.TS, 0).Format("2006-01-02 15:04"),
+		})
+	}
+	cw.Flush()
+}
