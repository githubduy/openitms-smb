# OpenITMS-SMB — MariaDB bundled, tune cho SMB (ADR-0002).
# CHỈ listen unix socket — không mở TCP (an ninh + GPL aggregation rõ ràng).
[mysqld]
basedir = @PREFIX@/mariadb
datadir = @DATA@/db
socket  = @DATA@/db/mysql.sock
user    = @DBUSER@
skip-networking = 1

character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# tune SMB: buffer pool ~25% RAM máy nhỏ — installer có thể tính lại theo RAM thật (P2-01)
innodb_buffer_pool_size = 512M
innodb_flush_log_at_trx_commit = 2
max_connections = 100

slow_query_log = 1
slow_query_log_file = @DATA@/db/slow.log
long_query_time = 2

[client]
socket = @DATA@/db/mysql.sock
